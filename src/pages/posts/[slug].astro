---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

function getEntrySlug(entry: { id: string; data: { slug?: string } }) {
  return entry.data.slug ?? entry.id.split('/').pop() ?? entry.id;
}

export async function getStaticPaths() {
  const postEntries = (await getCollection('posts')).filter((entry) => !entry.data.draft);
  return postEntries.map((entry) => ({
    params: { slug: entry.data.slug ?? entry.id.split('/').pop() ?? entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const currentPostSlug = getEntrySlug(entry);
const currentPostPath = `/posts/${currentPostSlug}/`;
const allPosts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const currentPostIndex = allPosts.findIndex(
  (post) => getEntrySlug(post) === currentPostSlug,
);

const previousPost = currentPostIndex < allPosts.length - 1 ? allPosts[currentPostIndex + 1] : null;
const nextPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;

const relatedPosts = allPosts
  .filter(
    (post) =>
      getEntrySlug(post) !== currentPostSlug &&
      post.data.category === entry.data.category,
  )
  .slice(0, 6);

const { Content, headings } = await render(entry);
---

<PostLayout
  frontmatter={entry.data}
  postSlug={currentPostSlug}
  postPath={currentPostPath}
  previousPost={previousPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
  headings={headings}
>
  <Content />
</PostLayout>
