---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const postEntries = await getCollection('posts');
  return postEntries.map((entry) => ({
    params: { slug: entry.data.slug || entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const currentPostPath = `/posts/${entry.data.slug || entry.id}/`;
const allPosts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const currentPostIndex = allPosts.findIndex(
  (post) => (post.data.slug || post.id) === (entry.data.slug || entry.id),
);

const previousPost = currentPostIndex < allPosts.length - 1 ? allPosts[currentPostIndex + 1] : null;
const nextPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;

const relatedPosts = allPosts
  .filter(
    (post) =>
      (post.data.slug || post.id) !== (entry.data.slug || entry.id) &&
      post.data.category === entry.data.category,
  )
  .slice(0, 6);

const { Content, headings } = await render(entry);
---

<PostLayout
  frontmatter={entry.data}
  postSlug={entry.data.slug || entry.id}
  postPath={currentPostPath}
  previousPost={previousPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
  headings={headings}
>
  <Content />
</PostLayout>
