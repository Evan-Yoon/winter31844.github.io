---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

function getEntrySlug(entry: { id: string; data: { slug?: string } }) {
  return entry.data.slug ?? entry.id.split('/').pop() ?? entry.id;
}

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const newsEntries = allPosts.filter((post) => {
    const slug = post.data.slug ?? post.id.split('/').pop() ?? post.id;
    return post.data.category === 'ai-news' && slug.includes('weekly-ai-news');
  });
  return newsEntries.map(entry => ({
    params: { slug: entry.data.slug ?? entry.id.split('/').pop() ?? entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | AI News | Evan Yoon`} description={entry.data.description}>
  <div class="news-detail-container fade-in-up">
    <header class="news-header">
      <div class="news-meta">
        <span class="news-date">{entry.data.date.toLocaleDateString('ko-KR')}</span>
        <span class="news-kicker">Weekly AI Summary</span>
      </div>
      <h1 class="news-title">{entry.data.title}</h1>
      <p class="news-intro">{entry.data.description}</p>
      {entry.data.thumbnail && (
        <img
          src={entry.data.thumbnail}
          alt={entry.data.title}
          class="news-cover"
          loading="eager"
          referrerpolicy="no-referrer"
        />
      )}
    </header>

    <article class="news-content">
      <Content />
    </article>

    <footer class="news-footer">
      <a href="/ai-news" class="back-link">
        <span class="arrow">←</span> Back to Archive
      </a>
    </footer  >
  </div>
</BaseLayout>

<style>
  .news-detail-container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 100px 2rem;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    min-height: 80vh;
  }

  .news-header {
    max-width: var(--col);
    margin: 0 auto 4rem;
    text-align: center;
  }

  .news-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .news-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-3);
  }

  .news-kicker {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--accent-soft);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .news-title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  .news-intro {
    font-size: 1.2rem;
    color: var(--ink-2);
    font-weight: 300;
    line-height: 1.7;
    font-style: italic;
  }

  .news-cover {
    display: block;
    width: 100%;
    max-width: 860px;
    margin: 2.5rem auto 0;
    border-radius: 18px;
    border: 1px solid var(--border);
    object-fit: cover;
    background: var(--bg-card);
  }

  .news-content {
    max-width: var(--col);
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--ink-2);
    font-weight: 300;
  }

  .news-content :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: var(--ink);
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .news-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .news-content :global(ul) {
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }

  .news-content :global(li) {
    margin-bottom: 0.75rem;
  }

  .news-content :global(strong) {
    color: var(--ink);
    font-weight: 500;
  }

  .news-footer {
    max-width: var(--col);
    margin: 4rem auto 0;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all var(--transition);
  }

  .back-link:hover { color: var(--accent); }
  .back-link .arrow { transition: transform var(--transition); }
  .back-link:hover .arrow { transform: translateX(-4px); }

  .fade-in-up {
    animation: fadeInUp 0.4s ease-out forwards;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 800px) {
    .news-detail-container { padding: 60px 1rem; border: none; }
  }
</style>
