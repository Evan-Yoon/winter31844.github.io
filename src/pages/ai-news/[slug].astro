---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

function getEntrySlug(entry: { id: string; data: { slug?: string } }) {
  return entry.data.slug ?? entry.id.split('/').pop() ?? entry.id;
}

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const newsEntries = allPosts.filter((post) => {
    const slug = post.data.slug ?? post.id.split('/').pop() ?? post.id;
    return !post.data.draft && post.data.category === 'ai-news' && slug.includes('weekly-ai-news');
  });
  return newsEntries.map(entry => ({
    params: { slug: entry.data.slug ?? entry.id.split('/').pop() ?? entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | AI News | Evan Yoon`} description={entry.data.description}>
  <div class="news-detail-container fade-in-up">
    <header class="news-header">
      <div class="news-meta">
        <span class="news-date">{entry.data.date.toLocaleDateString('ko-KR')}</span>
        <span class="news-kicker">Weekly AI Summary</span>
      </div>
      <h1 class="news-title">{entry.data.title}</h1>
      <p class="news-intro">{entry.data.description}</p>
      {entry.data.thumbnail && (
        <img
          src={entry.data.thumbnail}
          alt={entry.data.title}
          class="news-cover"
          loading="eager"
          referrerpolicy="no-referrer"
        />
      )}
    </header>

    <article class="news-content">
      <Content />
    </article>

    <footer class="news-footer">
      <a href="/ai-news" class="back-link">
        <span class="arrow">←</span> Back to Archive
      </a>
    </footer  >
  </div>
</BaseLayout>

<script is:inline>
  const flipCards = document.querySelectorAll('[data-flip-card]');

  const toggleCard = (card) => {
    const next = !card.classList.contains('is-flipped');
    flipCards.forEach((item) => {
      if (item !== card) item.classList.remove('is-flipped');
    });
    card.classList.toggle('is-flipped', next);
  };

  flipCards.forEach((card) => {
    card.addEventListener('click', (event) => {
      if (event.target.closest('a, button')) return;
      toggleCard(card);
    });

    card.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      toggleCard(card);
    });
  });

  document.querySelectorAll('[data-flip-close]').forEach((button) => {
    button.addEventListener('click', (event) => {
      event.stopPropagation();
      const card = button.closest('[data-flip-card]');
      if (card) card.classList.remove('is-flipped');
    });
  });
</script>

<style>
  .news-detail-container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 100px 2rem;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    min-height: 80vh;
  }

  .news-header {
    max-width: var(--col);
    margin: 0 auto 4rem;
    text-align: center;
  }

  .news-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .news-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-3);
  }

  .news-kicker {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--accent-soft);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .news-title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  .news-intro {
    font-size: 1.2rem;
    color: var(--ink-2);
    font-weight: 300;
    line-height: 1.7;
    font-style: italic;
  }

  .news-cover {
    display: block;
    width: 100%;
    max-width: 860px;
    margin: 2.5rem auto 0;
    border-radius: 18px;
    border: 1px solid var(--border);
    object-fit: cover;
    background: var(--bg-card);
  }

  .news-content {
    max-width: 1120px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--ink-2);
    font-weight: 300;
  }

  .news-content :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: var(--ink);
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .news-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .news-content :global(.weekly-news-intro) {
    max-width: 760px;
    margin: 0 auto 2rem;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--ink-2);
  }

  .news-content :global(.source-pill-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin: 0 auto 2.25rem;
    max-width: 820px;
  }

  .news-content :global(.source-pill) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.72);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-2);
  }

  .news-content :global(.weekly-news-note) {
    max-width: 760px;
    margin: 0 auto 2.5rem;
    padding: 1rem 1.1rem;
    border-radius: 16px;
    background: rgba(197, 97, 59, 0.08);
    border: 1px solid rgba(197, 97, 59, 0.14);
    color: var(--ink-2);
    font-size: 0.96rem;
  }

  .news-content :global(.flip-card-grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.35rem;
    margin: 0 auto 2rem;
  }

  .news-content :global(.flip-card) {
    position: relative;
    min-height: 520px;
    perspective: 1600px;
    cursor: pointer;
    outline: none;
  }

  .news-content :global(.flip-card-inner) {
    position: relative;
    width: 100%;
    min-height: 520px;
    transform-style: preserve-3d;
    transition: transform 0.72s cubic-bezier(.2, .7, .2, 1);
  }

  .news-content :global(.flip-card.is-flipped .flip-card-inner) {
    transform: rotateY(180deg);
  }

  .news-content :global(.flip-card-face) {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    backface-visibility: hidden;
    border-radius: 28px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(247,243,238,0.98));
    box-shadow: 0 16px 40px rgba(26, 21, 18, 0.08);
  }

  .news-content :global(.flip-card-front) {
    justify-content: flex-start;
  }

  .news-content :global(.flip-card-back) {
    transform: rotateY(180deg);
    padding: 1.35rem;
    background:
      radial-gradient(circle at top right, rgba(197, 97, 59, 0.16), transparent 34%),
      linear-gradient(180deg, #fbfaf7, #f4efe7);
  }

  .news-content :global(.flip-media) {
    aspect-ratio: 1 / 1;
    width: 100%;
    object-fit: cover;
    background: #e9e1d7;
    border-bottom: 1px solid rgba(26, 21, 18, 0.08);
  }

  .news-content :global(.flip-body) {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    padding: 1.15rem 1.15rem 1.3rem;
  }

  .news-content :global(.flip-title) {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    line-height: 1.18;
    margin: 0;
    color: var(--ink);
    text-align: center;
  }

  .news-content :global(.flip-summary) {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--ink-2);
  }

  .news-content :global(.flip-prompt) {
    display: none;
  }

  .news-content :global(.flip-back-top) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .news-content :global(.flip-kicker) {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .news-content :global(.flip-close) {
    border: 0;
    background: transparent;
    color: var(--ink-3);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    cursor: pointer;
  }

  .news-content :global(.flip-detail-title) {
    margin: 0 0 0.9rem;
    font-family: var(--font-serif);
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--ink);
  }

  .news-content :global(.flip-detail) {
    margin: 0 0 1rem;
    color: var(--ink-2);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .news-content :global(.flip-points) {
    display: grid;
    gap: 0.65rem;
    margin: 0 0 1rem;
    padding: 0;
    list-style: none;
  }

  .news-content :global(.flip-points li) {
    margin: 0;
    padding: 0.72rem 0.8rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(26, 21, 18, 0.08);
    color: var(--ink-2);
    font-size: 0.93rem;
    line-height: 1.55;
  }

  .news-content :global(.flip-links) {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .news-content :global(.flip-links a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.68rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.84);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .news-content :global(.flip-links a:hover) {
    color: var(--accent);
    border-color: rgba(197, 97, 59, 0.4);
  }

  .news-content :global(.weekly-footer-note) {
    max-width: 760px;
    margin: 2.4rem auto 0;
    color: var(--ink-3);
    font-size: 0.92rem;
    line-height: 1.7;
    text-align: center;
  }

  .news-content :global(ul) {
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }

  .news-content :global(li) {
    margin-bottom: 0.75rem;
  }

  .news-content :global(strong) {
    color: var(--ink);
    font-weight: 500;
  }

  .news-footer {
    max-width: var(--col);
    margin: 4rem auto 0;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--ink-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all var(--transition);
  }

  .back-link:hover { color: var(--accent); }
  .back-link .arrow { transition: transform var(--transition); }
  .back-link:hover .arrow { transform: translateX(-4px); }

  .fade-in-up {
    animation: fadeInUp 0.4s ease-out forwards;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 800px) {
    .news-detail-container { padding: 60px 1rem; border: none; }
    .news-content { max-width: 100%; }
    .news-content :global(.flip-card-grid) { grid-template-columns: 1fr; }
    .news-content :global(.flip-card),
    .news-content :global(.flip-card-inner) { min-height: 500px; }
  }
</style>
