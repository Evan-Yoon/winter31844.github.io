---
// src/pages/categories/[category]/[subcategory].astro
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');

  // 모든 category+subcategory 조합을 동적으로 수집
  const combos = new Map<string, { category: string; subcategory: string }>();
  allPosts.forEach(post => {
    if (post.data.subcategory) {
      const key = `${post.data.category}/${post.data.subcategory}`;
      combos.set(key, { category: post.data.category, subcategory: post.data.subcategory });
    }
  });

  return Array.from(combos.values()).map(({ category, subcategory }) => {
    const filteredPosts = allPosts
      .filter(p => p.data.category === category && p.data.subcategory === subcategory && !p.data.draft)
      .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

    return {
      params: { category, subcategory },
      props: { posts: filteredPosts, category, subcategory },
    };
  });
}

const { posts, category, subcategory } = Astro.props;

const catLabels: Record<string, string> = {
  project: '프로젝트',
  study: '학습 기록',
  explore: '탐구 기록',
};

// 서브카테고리 메타 정의 (label + 설명)
const subcatMeta: Record<string, { label: string; description: string }> = {
  'team-project': { label: 'Team Project', description: '팀으로 함께 기획하고 개발한 프로젝트 기록' },
  'personal-project': { label: 'Personal Project', description: '혼자 기획하고 처음부터 끝까지 만든 프로젝트 기록' },
  certification: { label: 'Certification', description: '자격증 취득 과정과 시험 후기를 모아둔 기록' },
  'self-study': { label: 'Self Study', description: '개인 공부와 학습 로드맵 기록' },
  visit: { label: 'Visit', description: '기업 방문, 행사, 프로그램 참가 기록' },
  'new-tech': { label: 'New Tech', description: '새 기술, 툴, 모델, 서비스 탐구 기록' },
};

const catDisplay = catLabels[category] || category;
const subcatDisplay = subcatMeta[subcategory]?.label ?? subcategory.toUpperCase();
const subcatDesc = subcatMeta[subcategory]?.description ?? '';
---

<BaseLayout title={`${subcatDisplay} | ${catDisplay} | Evan Yoon`}>
  <div class="page-wrap fade-in-up">
    <header class="page-header">
      <p class="page-eyebrow">
        <a href={`/categories/${category}`}>{catDisplay}</a>
        <span class="breadcrumb-sep">/</span>
        {subcatDisplay}
      </p>
      <h1 class="page-title">{subcatDisplay}</h1>
      {subcatDesc && <p class="page-subtitle">{subcatDesc}</p>}
      <p class="page-count">총 {posts.length}개의 글</p>
    </header>

    <div class="posts-list">
      {posts.length === 0 ? (
        <div class="empty-state">
          <p>아직 이 서랍장에는 작성된 글이 없습니다.<br />곧 멋진 기록들로 채워질 예정입니다!</p>
        </div>
      ) : (
        posts.map(post => (
          <article class="post-row">
            <div class="post-meta">
              <span class="post-date">{new Date(post.data.date).toLocaleDateString('ko-KR')}</span>
              {post.data.series && (
                <span class="post-series">{post.data.series}</span>
              )}
            </div>
            <div class="post-content">
              <h2 class="post-title">
                <a href={`/posts/${post.data.slug || post.id}`}>{post.data.title}</a>
              </h2>
              {post.data.description && <p class="post-desc">{post.data.description}</p>}
              {post.data.readTime && <span class="read-time">{post.data.readTime} min read</span>}
            </div>
          </article>
        ))
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap { max-width: var(--max-w); margin: 0 auto; padding: 20px 2rem 8rem; border-left: 1px solid var(--border); border-right: 1px solid var(--border); min-height: 80vh; }
  .fade-in-up { animation: fadeInUp 0.4s 0.1s ease-out forwards; opacity: 0; transform: translateY(10px); }
  @keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }

  .page-header { border-bottom: 1px solid var(--border); padding: 2rem 0 2rem; margin-bottom: 2rem; }
  .page-eyebrow {
    font-family: var(--font-mono); font-size: 0.75rem; color: var(--ink-3);
    letter-spacing: 0.1em; margin-bottom: 1rem;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .page-eyebrow a { color: var(--accent); }
  .page-eyebrow a:hover { text-decoration: underline; }
  .breadcrumb-sep { color: var(--border-strong); }
  .page-title { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 3rem); font-weight: 300; color: var(--ink); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
  .page-subtitle { font-size: 1.05rem; color: var(--ink-2); font-weight: 300; margin-bottom: 0.5rem; }
  .page-count { font-family: var(--font-mono); font-size: 0.8rem; color: var(--ink-3); }

  .empty-state { padding: 4rem 0; text-align: center; color: var(--ink-3); font-style: italic; background: var(--bg-hover); border-radius: 4px; border: 1px dashed var(--border-strong); }

  .posts-list { display: flex; flex-direction: column; }
  .post-row { display: grid; grid-template-columns: 200px 1fr; gap: 2rem; align-items: start; padding: 2.5rem 0; border-bottom: 1px solid var(--border-strong); }
  .post-row:hover .post-title a { color: var(--accent); }

  .post-meta { display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start; }
  .post-date { font-family: var(--font-mono); font-size: 0.85rem; color: var(--ink-3); }
  .post-series { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; padding: 3px 8px; border-radius: 2px; background: var(--accent-2-soft); color: var(--accent-2); }

  .post-title { font-family: var(--font-serif); font-size: 1.4rem; font-weight: 400; line-height: 1.3; margin-bottom: 0.4rem; }
  .post-title a { color: var(--ink); transition: color var(--transition); }
  .post-desc { font-size: 0.9rem; color: var(--ink-2); font-weight: 300; line-height: 1.5; margin-bottom: 0.4rem; }
  .read-time { font-family: var(--font-mono); font-size: 0.75rem; color: var(--ink-3); }

  @media (max-width: 768px) {
    .page-wrap { border: none; padding-top: 20px; }
    .post-row { grid-template-columns: 1fr; gap: 1rem; padding: 2rem 0; }
    .post-meta { flex-direction: row; align-items: center; flex-wrap: wrap; }
  }
</style>
