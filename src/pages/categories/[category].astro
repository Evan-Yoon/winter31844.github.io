---
// src/pages/categories/[category].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const categories = ['project', 'study', 'explore'];

  return categories.map(category => {
    const filteredPosts = allPosts
      .filter(post => post.data.category === category && !post.data.draft)
      .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

    // 이 카테고리에 속한 서브카테고리 목록 수집
    const subcategories = [...new Set(
      filteredPosts
        .filter(p => p.data.subcategory)
        .map(p => p.data.subcategory as string)
    )];

    return {
      params: { category },
      props: { posts: filteredPosts, categoryName: category, subcategories },
    };
  });
}

const { categoryName, posts, subcategories } = Astro.props;

const catLabels: Record<string, string> = {
  'project': '🚀 Projects (프로젝트)',
  'study': '📚 Study (학습 기록)',
  'explore': '🧪 Explore (탐구 기록)'
};

const subcatMeta: Record<string, { label: string; description: string }> = {
  'team-project': { label: 'Team Project', description: '팀으로 함께 만든 프로젝트' },
  'personal-project': { label: 'Personal Project', description: '혼자 기획하고 개발한 프로젝트' },
  certification: { label: 'Certification', description: '자격증 취득 과정과 시험 후기' },
  bootcamp: { label: 'Bootcamp', description: 'Intel AI 과정 수업 기록' },
  'self-study': { label: 'Self Study', description: '팀 스터디 및 개인 자습 기록' },
  'field-visit': { label: 'Field Visit', description: '직접 현장을 찾아간 방문 기록' },
  lecture: { label: 'Lecture', description: '외부 강사 특강 및 강의 기록' },
  'new-tech': { label: 'New Tech', description: '새 기술, 툴, 모델, 서비스 탐구' },
  essay: { label: 'Essay', description: '개인 이야기, 경험담, 생각 정리' },
};

const displayTitle = catLabels[categoryName] || categoryName;
const hasSubcategories = subcategories.length > 0;
---

<BaseLayout title={`${displayTitle} | Evan Yoon`}>
  <div class="page-wrap fade-in-up">
    <header class="page-header">
      <p class="page-eyebrow">CATEGORY</p>
      <h1 class="page-title">{displayTitle}</h1>
      <p class="page-subtitle">총 {posts.length}개의 글이 분류되어 있습니다.</p>
    </header>

    {hasSubcategories && (
      <section class="subcategory-nav">
        <p class="section-label">SUBCATEGORIES</p>
        <div class="subcat-grid">
          {subcategories.map(subcat => {
            const meta = subcatMeta[subcat];
            const count = posts.filter(p => p.data.subcategory === subcat).length;
            return (
              <a
                href={`/categories/${categoryName}/${subcat}`}
                class="subcat-card"
              >
                <span class="subcat-label">{meta?.label ?? subcat.toUpperCase()}</span>
                <span class="subcat-desc">{meta?.description ?? ''}</span>
                <span class="subcat-count">{count}개의 글</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <div class="posts-list">
      {posts.length === 0 ? (
        <div class="empty-state">
          <p>아직 이 서랍장에는 작성된 글이 없습니다.<br>곧 멋진 기록들로 채워질 예정입니다!</p>
        </div>
      ) : (
        posts.map(post => (
          <article class="post-row">
            <div class="post-meta">
              <span class="post-date">{new Date(post.data.date).toLocaleDateString('ko-KR')}</span>
              {post.data.subcategory ? (
                <a
                  href={`/categories/${categoryName}/${post.data.subcategory}`}
                  class={`post-cat badge-${post.data.category || 'explore'} subcat-badge`}
                >
                  {subcatMeta[post.data.subcategory]?.label ?? post.data.subcategory.toUpperCase()}
                </a>
              ) : (
                <span class={`post-cat badge-${post.data.category || 'explore'}`}>{post.data.category}</span>
              )}
            </div>
            <div class="post-content">
              <h2 class="post-title">
                <a href={`/posts/${post.data.slug || post.id}`}>{post.data.title}</a>
              </h2>
              {post.data.description && <p class="post-desc">{post.data.description}</p>}
              <div class="post-stats">
                {post.data.readTime && <span class="read-time">{post.data.readTime} min read</span>}
                <span
                  class="post-view-count"
                  data-post-views
                  data-goatcounter-path={`/posts/${post.data.slug || post.id}/`}
                >
                  views -
                </span>
              </div>
            </div>
          </article>
        ))
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page-wrap { max-width: var(--max-w); margin: 0 auto; padding: 20px 2rem 8rem; border-left: 1px solid var(--border); border-right: 1px solid var(--border); min-height: 80vh; }
  .fade-in-up { animation: fadeInUp 0.4s 0.1s ease-out forwards; opacity: 0; transform: translateY(10px); }
  @keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }

  .page-header { border-bottom: 1px solid var(--border); padding: 2rem 0 2rem; margin-bottom: 2rem; }
  .page-eyebrow { font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); letter-spacing: 0.1em; margin-bottom: 1rem; }
  .page-title { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 3rem); font-weight: 300; color: var(--ink); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
  .page-subtitle { font-size: 1.05rem; color: var(--ink-2); font-weight: 300; }

  /* ── 서브카테고리 섹션 ── */
  .subcategory-nav { margin-bottom: 3rem; }
  .section-label { font-family: var(--font-mono); font-size: 0.7rem; color: var(--ink-3); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 1rem; }
  .subcat-grid { display: flex; flex-wrap: wrap; gap: 1rem; }
  .subcat-card {
    display: flex; flex-direction: column; gap: 0.3rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: var(--bg-card);
    transition: border-color var(--transition), background var(--transition);
    min-width: 180px;
  }
  .subcat-card:hover { border-color: var(--accent); background: var(--bg-hover); }
  .subcat-label { font-family: var(--font-mono); font-size: 0.9rem; font-weight: 500; color: var(--accent); }
  .subcat-desc { font-size: 0.8rem; color: var(--ink-2); font-weight: 300; }
  .subcat-count { font-family: var(--font-mono); font-size: 0.7rem; color: var(--ink-3); margin-top: 0.2rem; }

  /* ── 포스트 목록 ── */
  .empty-state { padding: 4rem 0; text-align: center; color: var(--ink-3); font-style: italic; background: var(--bg-hover); border-radius: 4px; border: 1px dashed var(--border-strong); }

  .posts-list { display: flex; flex-direction: column; }
  .post-row { display: grid; grid-template-columns: 200px 1fr; gap: 2rem; align-items: start; padding: 2.5rem 0; border-bottom: 1px solid var(--border-strong); }
  .post-row:hover .post-title a { color: var(--accent); }

  .post-meta { display: flex; flex-direction: column; gap: 0.75rem; align-items: flex-start; }
  .post-date { font-family: var(--font-mono); font-size: 0.85rem; color: var(--ink-3); }
  .post-cat { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; border-radius: 2px; }
  .subcat-badge { text-decoration: none; transition: opacity var(--transition); }
  .subcat-badge:hover { opacity: 0.75; }

  .badge-study { background: var(--accent-2-soft); color: var(--accent-2); }
  .badge-project { background: #E6F0E6; color: #2E7D32; }
  .badge-explore { background: var(--accent-soft); color: var(--accent); }
  [data-theme="dark"] .badge-project { background: #1A2E1A; color: #66BB6A; }

  .post-title { font-family: var(--font-serif); font-size: 1.4rem; font-weight: 400; line-height: 1.3; margin-bottom: 0.4rem; }
  .post-title a { color: var(--ink); transition: color var(--transition); }
  .post-desc { font-size: 0.9rem; color: var(--ink-2); font-weight: 300; line-height: 1.5; margin-bottom: 0.4rem; }
  .post-stats { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .read-time { font-family: var(--font-mono); font-size: 0.75rem; color: var(--ink-3); }
  .post-view-count { font-family: var(--font-mono); font-size: 0.75rem; color: var(--ink-3); }

  @media (max-width: 768px) {
    .page-wrap { border: none; padding-top: 20px; }
    .post-row { grid-template-columns: 1fr; gap: 1rem; padding: 2rem 0; }
    .post-meta { flex-direction: row; align-items: center; flex-wrap: wrap; }
    .subcat-grid { flex-direction: column; }
    .subcat-card { min-width: unset; }
  }
</style>
