---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

function getEntrySlug(entry) {
  return entry.data.slug ?? entry.id.split('/').pop() ?? entry.id;
}

function isWeeklyNews(entry) {
  return !entry.data.draft && entry.data.category === 'ai-news' && getEntrySlug(entry).includes('weekly-ai-news');
}

// 마크다운 글 데이터를 불러와서 최신순으로 정렬하고 3개만 자릅니다.
const allPosts = await getCollection('posts');

// Filter recent posts (excluding ai-news) for the home page list
const recentPosts = allPosts
  .filter(post => !post.data.draft && post.data.category !== 'ai-news')
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);

// Get latest AI News
const latestNews = allPosts
  .filter(post => isWeeklyNews(post))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())[0];
---

<BaseLayout>
  <header class="hero">
    <div class="hero-content">
      <p class="hero-eyebrow">Evan Yoon / Aspiring Developer</p>
      <h1 class="hero-title">
        Former HR Specialist.<br>
        Former Blizzard GM.<br>
        Now Building in <em class="acc-2">AI & Dev</em>.
      </h1>
      <p class="hero-desc">
        From managing people at Josun Palace to writing code — honest records of exploring AI, software development, and what it takes to build things that actually matter.
      </p>
      <div class="hero-cta">
        <a href="/posts" class="btn-primary">Explore My Code</a>
        <a href="#about" class="btn-ghost">Read My Story</a>
      </div>

      <div class="visitor-stats">
        <div class="stat-item">
          <span class="stat-label">VISITS</span>
          <span class="stat-value" id="stat-total">—</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-label">TODAY</span>
          <span class="stat-value" id="stat-daily">—</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-label">POSTS</span>
          <span class="stat-value">{allPosts.length}</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-label">DAYS</span>
          <span class="stat-value" id="stat-days">—</span>
        </div>
      </div>
      <a
        href="/snake_game_evan.html"
        class="snake-easter-egg"
        aria-label="Open hidden snake game"
        title="A tiny visitor is hiding here"
      >
        <svg viewBox="0 0 72 40" aria-hidden="true">
          <path class="snake-body" d="M7 28c1-4 3-7 6-8 4-2 9-1 14 2 4 3 8 5 12 5 3 0 6-1 8-3 2-1 3-3 4-6" />
          <path class="snake-body" d="M8 29c4 2 9 3 14 2 5-1 9-4 13-6 5-3 9-5 14-5 4 0 8 1 11 3" />
          <path class="snake-head" d="M49 13c0-4 3-7 7-7 5 0 9 3 9 8 0 5-4 9-9 9-4 0-7-4-7-10Z" />
          <circle class="snake-eye" cx="56.5" cy="13.5" r="1.4" />
          <path class="snake-tongue" d="M64 16h5m0 0-2-2m2 2-2 2" />
        </svg>
      </a>
    </div>
  </header>

  <section class="recent-posts-section">
    <div class="section-header">
      <div>
        <div class="section-num">01 / RECENT POSTS</div>
        <h2 class="section-title">기록과 공유</h2>
      </div>
      <a href="/posts" class="view-all">All Posts →</a>
    </div>
    
    <div class="posts-grid">
      {recentPosts.map(post => (
        <article class="post-card" data-summary={post.data.description || "이 포스트의 핵심 내용을 확인해보세요."}>
          <div class="post-card-meta">
            <span class={`post-cat-badge badge-${post.data.category || 'explore'}`}>{post.data.category || 'explore'}</span>
            <span class="post-date">{new Date(post.data.date).toLocaleDateString('ko-KR')}</span>
          </div>
          <h3 class="post-card-title">
            <a href={`/posts/${getEntrySlug(post)}`}>{post.data.title}</a>
          </h3>
          <div class="post-card-footer">
            <span class="read-time">{post.data.readTime ? `${post.data.readTime} min read` : ''}</span>
            <span
              class="post-view-count"
              data-post-views
              data-goatcounter-path={`/posts/${getEntrySlug(post)}/`}
            >
              views -
            </span>
            <span class="read-arrow">→</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="about" class="about-section">
    <div class="about-inner">
      <div class="about-heading-wrap">
        <div class="section-num">02 / ABOUT</div>
        <h2 class="section-title">사람을 읽는 감각으로,<br>AI와 개발을 배웁니다.</h2>
      </div>
      <div class="about-body-wrap">
        <p class="about-body">
          조선 팰리스 럭셔리 컬렉션 호텔에서 HR 담당자로 3년 반을 일했습니다. 채용과 조직 문화를 담당하며 사람들이 무엇을 원하고 어디서 막히는지 파악하는 일에 집중했는데, 그 감각이 개발을 하는 데도 생각보다 많이 남아 있습니다.<br><br>
          이후 AI와 소프트웨어 개발에 관심이 깊어지면서 자연스럽게 이 방향으로 옮겨왔습니다. 지금은 Java, Python, Flutter를 공부하며 사람에게 실질적으로 도움이 되는 것을 직접 만드는 개발자를 목표로 하고 있습니다.
        </p>
        <div class="about-skills">
          <span class="skill-chip">Java</span>
          <span class="skill-chip">Python</span>
          <span class="skill-chip">Flutter</span>
          <span class="skill-chip">AI / ML</span>
          <span class="skill-chip">AWS</span>
          <span class="skill-chip">Git</span>
        </div>
      </div>
    </div>
  </section>
  
  <section class="activity-section">
    <div class="section-header">
      <div>
        <div class="section-num">03 / ACTIVITY</div>
        <h2 class="section-title">Build History</h2>
      </div>
    </div>
    
    <div class="activity-container">
      <div class="github-graph-wrap">
        <div id="github-calendar">
          <p class="activity-loading">활동 내역을 불러오고 있습니다..</p>
        </div>
      </div>
      
      <div class="recent-commits-wrap">
        <div class="activity-copy">
          <div>
            <h3 class="commits-title">Recent Work</h3>
            <p class="commits-desc">최근 공개 GitHub 활동을 핵심만 요약했습니다.</p>
          </div>
        </div>
        <div id="recent-commits-list">
          <p class="activity-loading">커밋 내역을 불러오는 중..</p>
        </div>
        <a href="https://github.com/Evan-Yoon" target="_blank" class="github-link-button">
          Full GitHub Profile →
        </a>
      </div>
    </div>
  </section>

  <section id="journey-section" class="timeline-section">
    <div class="section-header">
      <div>
        <div class="section-num">05 / JOURNEY</div>
        <h2 class="section-title">The Blueprint</h2>
      </div>
    </div>
    <div class="timeline">
      <div class="tl-item">
        <div class="tl-date">Now</div>
        <div class="tl-content">
          <p class="tl-title">Aspiring Software Developer</p>
          <p class="tl-desc">AI &amp; Tech Stack deep dive (Intel AI program)</p>
        </div>
      </div>
      <div class="tl-item accent">
        <div class="tl-date">2021 – 2024</div>
        <div class="tl-content">
          <p class="tl-title">Josun Palace, Luxury Collection Hotel</p>
          <p class="tl-desc">HR Specialist (Recruitment, Organizational Culture)</p>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-date tl-mono">Former</div>
        <div class="tl-content">
          <p class="tl-title">Blizzard Entertainment</p>
          <p class="tl-desc">Game Master (Customer Resolution &amp; Service Operation)</p>
        </div>
      </div>
    </div>
  </section>

  {latestNews && (
    <section id="home-ai-news-section" class="ai-news-section">
      <div class="section-header">
        <div>
          <div class="section-num">04 / AI NEWS</div>
          <h2 class="section-title">Weekly AI Summary</h2>
        </div>
        <a href="/ai-news" class="view-all">All News Archive →</a>
      </div>
      
      <div class="news-preview-card">
        <div class="news-preview-meta">
          <span class="news-preview-date">{latestNews.data.date.toLocaleDateString('ko-KR')}</span>
          <span class="news-preview-kicker">Latest Update</span>
        </div>
        <h3 class="news-preview-title">
          <a href={`/ai-news/${getEntrySlug(latestNews)}`}>{latestNews.data.title}</a>
        </h3>
        <p class="news-preview-desc">{latestNews.data.description}</p>
        <div class="news-preview-footer">
          <a href={`/ai-news/${getEntrySlug(latestNews)}`} class="news-preview-link">
            Read Full Summary <span class="arrow">→</span>
          </a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<script is:inline>
  (() => {
    const journeySection = document.getElementById('journey-section');
    const aiNewsSection = document.getElementById('home-ai-news-section');
    if (journeySection && aiNewsSection) {
      journeySection.parentNode.insertBefore(aiNewsSection, journeySection);
    }
  })();
</script>

<script>
  import { initializeApp } from 'firebase/app';
  import { getDatabase, get, ref, runTransaction } from 'firebase/database';

  const firebaseConfig = {
    apiKey: 'AIzaSyCNkdX0A83XXEK-FIjqPt7b8iZxJ5mlw_4',
    authDomain: 'blog-stats-3b3fd.firebaseapp.com',
    databaseURL: 'https://blog-stats-3b3fd-default-rtdb.firebaseio.com',
    projectId: 'blog-stats-3b3fd',
    storageBucket: 'blog-stats-3b3fd.firebasestorage.app',
    messagingSenderId: '1009895082497',
    appId: '1:1009895082497:web:938bf796556e7889570e00',
    measurementId: 'G-Y6835HX2J5'
  };

  const firebaseApp = initializeApp(firebaseConfig);
  const database = getDatabase(firebaseApp);
  // ── 운영일 계산 (2025-11-28 기준) ──
  const launch = new Date('2025-11-28T00:00:00+09:00');
  const today = new Date();
  const days = Math.floor((today.getTime() - launch.getTime()) / (1000 * 60 * 60 * 24));
  const daysEl = document.getElementById('stat-days');
  if (daysEl) daysEl.textContent = days.toLocaleString('ko-KR');

  const todayKst = new Intl.DateTimeFormat('en-CA', {
    timeZone: 'Asia/Seoul',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(today);

  // ── GoatCounter 전체 방문자 수 ──
  fetch('https://evan-yoon.goatcounter.com/counter/TOTAL.json')
    .then(r => { if (!r.ok) throw new Error(); return r.json(); })
    .then(data => {
      const el = document.getElementById('stat-total');
      if (el && data.count != null) el.textContent = Number(data.count).toLocaleString('ko-KR');
    })
    .catch(() => {});

  // ── Firebase 오늘 방문자 수 ──
  (async () => {
    const el = document.getElementById('stat-daily');
    const dailyRef = ref(database, `visits/${todayKst}`);
    const storageKey = `visited_${todayKst}`;
    try {
      // 오늘 카운트 읽기
      const snapshot = await get(dailyRef);
      const current = snapshot.exists() ? snapshot.val() : 0;
      if (el) el.textContent = Number(current).toLocaleString('ko-KR');

      // 하루에 한 번만 카운트 (같은 브라우저/기기 기준)
      if (!localStorage.getItem(storageKey)) {
        const result = await runTransaction(dailyRef, (value) => (value || 0) + 1);
        localStorage.setItem(storageKey, '1');
        if (result.committed && el) {
          el.textContent = Number(result.snapshot.val() ?? current).toLocaleString('ko-KR');
        }
      }
    } catch (error) {
      console.error('Failed to load daily visits from Firebase.', error);
    }
  })();

  // ── GitHub Activity Implementation ──
  (async () => {
    // 1. GitHub Calendar
    const calendarRoot = document.getElementById('github-calendar');

    function showCalendarFallback(message) {
      if (!calendarRoot) return;
      calendarRoot.innerHTML = `
        <p class="no-activity">${message}</p>
        <a href="https://github.com/Evan-Yoon" target="_blank" rel="noreferrer" class="github-link-button">
          Open GitHub Profile →
        </a>
      `;
    }

    try {
      const script = document.createElement('script');
      script.src = "https://unpkg.com/github-calendar@latest/dist/github-calendar.min.js";
      script.onerror = () => {
        showCalendarFallback('GitHub activity graph could not be loaded right now.');
      };
      script.onload = () => {
        const loadCalendar = window.GitHubCalendar;
        if (typeof loadCalendar !== 'function') {
          showCalendarFallback('GitHub activity graph could not be loaded right now.');
          return;
        }

        loadCalendar("#github-calendar", "Evan-Yoon", {
          responsive: true,
          tooltips: true,
          summary_text: " ",
          global_stats: false
        })
          .then(() => {
            const calendar = document.querySelector('#github-calendar');
            if (!calendar) return;
            const toHide = calendar.querySelectorAll('.year-tabs, .contrib-footer, h2, .sr-only, .float-left.text-gray');
            toHide.forEach((el) => {
              if (el instanceof HTMLElement) {
                el.style.display = 'none';
              }
            });
          })
          .catch(() => {
            showCalendarFallback('GitHub activity graph could not be loaded right now.');
          });
      };
      document.head.appendChild(script);
      
      const link = document.createElement('link');
      link.rel = "stylesheet";
      link.href = "https://unpkg.com/github-calendar@latest/dist/github-calendar-responsive.css";
      document.head.appendChild(link);
    } catch (e) {
      console.error("Failed to load GitHub Calendar", e);
      showCalendarFallback('GitHub activity graph could not be loaded right now.');
    }

    // 2. Recent Commits
    const commitsList = document.getElementById('recent-commits-list');
    if (!commitsList) return;

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function summarizeDay(events) {
      const repoSet = new Set();
      let pushEvents = 0;
      let pushedCommits = 0;
      let createEvents = 0;
      let pullRequests = 0;
      const highlights = [];

      events.forEach((event) => {
        const repo = (event.repo?.name || '').replace('Evan-Yoon/', '') || 'Repository';
        repoSet.add(repo);

        if (event.type === 'PushEvent') {
          pushEvents += 1;
          const commits = Array.isArray(event.payload?.commits) ? event.payload.commits : [];
          pushedCommits += commits.length || 1;
          if (commits[0]?.message) highlights.push(commits[0].message);
        } else if (event.type === 'CreateEvent') {
          createEvents += 1;
          const refType = event.payload?.ref_type || 'item';
          const refName = event.payload?.ref || repo;
          highlights.push(`Created ${refType}: ${refName}`);
        } else if (event.type === 'PullRequestEvent') {
          pullRequests += 1;
          if (event.payload?.pull_request?.title) highlights.push(event.payload.pull_request.title);
        }
      });

      const actionParts = [];
      if (pushEvents > 0) actionParts.push(`${pushEvents} push${pushEvents > 1 ? 'es' : ''}`);
      if (pullRequests > 0) actionParts.push(`${pullRequests} PR${pullRequests > 1 ? 's' : ''}`);
      if (createEvents > 0) actionParts.push(`${createEvents} create${createEvents > 1 ? 's' : ''}`);

      const repos = Array.from(repoSet);
      const repoSummary = repos.length > 2
        ? `${repos.slice(0, 2).join(', ')} +${repos.length - 2}`
        : repos.join(', ');

      return {
        date: new Date(events[0].created_at).toLocaleDateString('ko-KR'),
        badge: `${events.length} update${events.length > 1 ? 's' : ''}`,
        summary: actionParts.length > 0
          ? `${actionParts.join(' • ')}${pushedCommits > 0 ? ` • ${pushedCommits} commit${pushedCommits > 1 ? 's' : ''}` : ''}`
          : 'Recent public activity',
        detail: highlights[0] || 'Recent public activity',
        repos: repoSummary || 'Evan-Yoon',
      };
    }

    try {
      const res = await fetch('https://api.github.com/users/Evan-Yoon/events/public');
      const events = await res.json();
      
      if (!Array.isArray(events)) throw new Error("Invalid response");

      const pushes = events
        .filter(e => e.type === 'PushEvent' || e.type === 'CreateEvent' || e.type === 'PullRequestEvent')
        .slice(0, 12);

      if (pushes.length === 0) {
        commitsList.innerHTML = '<p class="no-activity">최근 작업 내역이 없습니다.</p>';
        return;
      }

      const groupedByDay = [];
      const dayMap = new Map();
      pushes.forEach((event) => {
        const dayKey = new Date(event.created_at).toLocaleDateString('en-CA', { timeZone: 'Asia/Seoul' });
        if (!dayMap.has(dayKey)) {
          dayMap.set(dayKey, []);
          groupedByDay.push(dayKey);
        }
        dayMap.get(dayKey).push(event);
      });

      const dailyCards = groupedByDay.slice(0, 3).map((dayKey) => summarizeDay(dayMap.get(dayKey)));

      commitsList.innerHTML = dailyCards.map((card) => {
        return `
          <div class="commit-item">
            <div class="commit-top">
              <span class="commit-repo">Evan-Yoon</span>
              <span class="commit-badge">${escapeHtml(card.badge)}</span>
            </div>
            <p class="commit-msg">${escapeHtml(card.summary)}</p>
            <p class="commit-detail">${escapeHtml(card.detail)}</p>
            <div class="commit-bottom">
              <span class="commit-repos">${escapeHtml(card.repos)}</span>
              <span class="commit-date">${escapeHtml(card.date)}</span>
            </div>
          </div>
        `;
      }).join('');
    } catch (e) {
      console.error("Failed to fetch Github events", e);
      commitsList.innerHTML = '<p class="no-activity">활동 내역을 불러올 수 없습니다.</p>';
    }
  })();
</script>

<style>
  /* ─── INDEX SPECIFIC STYLES ─── */
  .hero { min-height: 60vh; display: flex; align-items: center; max-width: var(--max-w); margin: 0 auto; padding: 20px 2rem; border-left: 1px solid var(--border); border-right: 1px solid var(--border); }
  .hero-content { max-width: 800px; margin: 0 auto; padding: 4rem 0; }
  .hero-eyebrow { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 2rem; font-family: var(--font-mono); }
  .hero-title { font-family: var(--font-serif); font-size: clamp(2.8rem, 5.5vw, 4.2rem); font-weight: 300; line-height: 1.05; letter-spacing: -0.04em; color: var(--ink); margin-bottom: 2rem; }
  .hero-title em.acc-2 { font-style: italic; color: var(--accent-2); }
  .hero-desc { font-size: 1.05rem; line-height: 1.75; color: var(--ink-2); max-width: 44ch; margin-bottom: 3.5rem; font-weight: 300; }
  .hero-cta { display: flex; gap: 1rem; align-items: center; }

  .visitor-stats { display: flex; align-items: center; gap: 2rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); }
  .stat-item { display: flex; flex-direction: column; gap: 0.3rem; }
  .stat-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--ink-3); letter-spacing: 0.1em; }
  .stat-value { font-family: var(--font-mono); font-size: 1.4rem; color: var(--ink); font-weight: 400; }
  .stat-divider { width: 1px; height: 2rem; background: var(--border-strong); }
  .snake-easter-egg {
    position: absolute;
    right: clamp(1rem, 4vw, 2.5rem);
    bottom: clamp(1rem, 3vw, 2rem);
    width: 56px;
    height: 32px;
    opacity: 0.42;
    transition: transform var(--transition), opacity var(--transition), filter var(--transition);
    filter: drop-shadow(0 4px 10px rgba(34, 197, 94, 0.18));
  }
  .snake-easter-egg:hover {
    opacity: 0.95;
    transform: translateY(-2px) rotate(-3deg);
  }
  .snake-easter-egg svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }
  .snake-easter-egg .snake-body,
  .snake-easter-egg .snake-tongue {
    fill: none;
    stroke: #22c55e;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 3.5;
  }
  .snake-easter-egg .snake-head {
    fill: #86efac;
    stroke: #22c55e;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.4;
  }
  .snake-easter-egg .snake-eye {
    fill: #14532d;
  }
  .btn-primary { padding: 12px 28px; background: var(--ink); color: var(--bg); font-size: 0.8rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; transition: all var(--transition); }
  .btn-primary:hover { background: var(--accent); }
  .btn-ghost { padding: 12px 28px; border: 1px solid var(--border-strong); color: var(--ink-2); font-size: 0.8rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; transition: all var(--transition); }
  .btn-ghost:hover { background: var(--bg-hover); color: var(--ink); }

  section { max-width: var(--max-w); margin: 0 auto; padding: 6rem 2rem; border-left: 1px solid var(--border); border-right: 1px solid var(--border); }
  .section-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 4rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
  .section-title { font-family: var(--font-serif); font-size: clamp(1.6rem, 3.5vw, 2.3rem); font-weight: 300; color: var(--ink); line-height: 1.2; letter-spacing: -0.02em; }
