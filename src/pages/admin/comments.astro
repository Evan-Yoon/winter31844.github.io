---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Comment Admin | Evan Yoon" description="Comment moderation dashboard">
  <section class="admin-auth-shell" data-admin-auth-screen>
    <div class="admin-auth-card">
      <p class="admin-kicker">Admin</p>
      <h1 class="admin-title">Comment Login</h1>
      <p class="admin-subtitle">로그인하지 않은 상태에서는 이 화면만 표시됩니다.</p>
      <form class="admin-form" data-admin-login novalidate>
        <label class="admin-field">
          <span>Email</span>
          <input type="email" name="email" placeholder="admin@example.com" required />
        </label>
        <label class="admin-field">
          <span>Password</span>
          <input type="password" name="password" placeholder="Password" required />
        </label>
        <button type="submit" class="admin-button">Login</button>
        <p class="admin-status" data-admin-auth-status aria-live="polite"></p>
      </form>
    </div>
  </section>

  <section class="admin-shell" data-admin-dashboard hidden>
    <div class="admin-header">
      <div>
        <p class="admin-kicker">Admin</p>
        <h1 class="admin-title">Comment Dashboard</h1>
        <p class="admin-subtitle">신고 여부와 관계없이 모든 댓글을 확인하고 바로 삭제할 수 있습니다.</p>
      </div>
      <div class="admin-actions">
        <span class="admin-user" data-admin-user>Signed out</span>
        <button type="button" class="admin-button admin-button-ghost" data-admin-logout>Logout</button>
      </div>
    </div>

    <section class="admin-card admin-card-wide">
      <div class="admin-panel" data-admin-panel>
        <div class="admin-card-head">
          <div>
            <h2 class="admin-card-title">Comments</h2>
            <p class="admin-card-copy">All comments are listed here. Reported comments float to the top, but any comment can be deleted immediately.</p>
          </div>
          <div class="admin-toolbar">
            <div class="admin-filters" role="tablist" aria-label="Comment filters">
              <button type="button" class="admin-filter is-active" data-admin-filter="all" aria-pressed="true">All</button>
              <button type="button" class="admin-filter" data-admin-filter="reported" aria-pressed="false">Reported</button>
            </div>
            <button type="button" class="admin-button admin-button-ghost" data-admin-refresh>Refresh</button>
          </div>
        </div>
        <div class="admin-status-row">
          <span data-admin-summary>Not loaded</span>
          <span data-admin-access>Admin access required</span>
        </div>
        <div class="admin-comments" data-admin-comments>
          <p class="admin-empty">No comments found.</p>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>

<script>
  import { onAuthStateChanged, signInWithEmailAndPassword, signOut } from 'firebase/auth';
  import { get, ref, remove, update } from 'firebase/database';
  import { getFirebaseAuth, getFirebaseDatabase } from '../../lib/firebase/client';

  const auth = getFirebaseAuth('comments-admin');
  const database = getFirebaseDatabase('comments-admin');

  const loginForm = document.querySelector<HTMLFormElement>('[data-admin-login]');
  const authStatus = document.querySelector<HTMLElement>('[data-admin-auth-status]');
  const authScreen = document.querySelector<HTMLElement>('[data-admin-auth-screen]');
  const adminDashboard = document.querySelector<HTMLElement>('[data-admin-dashboard]');
  const userLabel = document.querySelector<HTMLElement>('[data-admin-user]');
  const logoutButton = document.querySelector<HTMLElement>('[data-admin-logout]');
  const refreshButton = document.querySelector<HTMLButtonElement>('[data-admin-refresh]');
  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-admin-filter]'));
  const commentsRoot = document.querySelector<HTMLElement>('[data-admin-comments]');
  const adminPanel = document.querySelector<HTMLElement>('[data-admin-panel]');
  const summaryLabels = Array.from(document.querySelectorAll<HTMLElement>('[data-admin-summary]'));
  const accessLabels = Array.from(document.querySelectorAll<HTMLElement>('[data-admin-access]'));
  let hasAdminAccess = false;
  let activeFilter: 'all' | 'reported' = 'all';

  const setAuthStatus = (message: string, tone = 'neutral') => {
    if (!authStatus) return;
    authStatus.textContent = message;
    authStatus.dataset.tone = tone;
  };

  const setSummary = (message: string) => {
    summaryLabels.forEach((node) => {
      node.textContent = message;
    });
  };

  const setAccess = (message: string) => {
    accessLabels.forEach((node) => {
      node.textContent = message;
    });
  };

  const setActiveFilter = (filter: 'all' | 'reported') => {
    activeFilter = filter;
    filterButtons.forEach((button) => {
      const isActive = button.dataset.adminFilter === filter;
      button.classList.toggle('is-active', isActive);
      button.setAttribute('aria-pressed', String(isActive));
    });
  };

  const setScreenState = (isAuthenticatedView: boolean) => {
    if (authScreen instanceof HTMLElement) {
      authScreen.hidden = isAuthenticatedView;
    }
    if (adminDashboard instanceof HTMLElement) {
      adminDashboard.hidden = !isAuthenticatedView;
    }
  };

  const setAdminView = (isUnlocked: boolean) => {
    if (adminPanel instanceof HTMLElement) {
      adminPanel.hidden = !isUnlocked;
    }
  };

  const formatDate = (value: number | string | Date) => {
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '-';
    return date.toLocaleString('ko-KR');
  };

  const escapeHtml = (value: any) =>
    String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  async function checkAdminAccess(uid: string) {
    const snapshot = await get(ref(database, `admins/${uid}`));
    return snapshot.val() === true;
  }

  const collectDescendantIds = (items: Array<any>, parentId: string) => {
    const descendants: string[] = [];
    const queue = [parentId];

    while (queue.length > 0) {
      const currentId = queue.shift();
      const children = items.filter((item) => item.parentId === currentId).map((item) => item.commentId);
      children.forEach((childId) => {
        descendants.push(childId);
        queue.push(childId);
      });
    }

    return descendants;
  };

  async function loadComments() {
    if (!hasAdminAccess) {
      setAdminView(false);
      setSummary('Not loaded');
      return;
    }

    try {
      const snapshot = await get(ref(database, 'comments'));
      const raw = snapshot.val() || {};
      const items = Object.entries(raw).flatMap(([postSlug, comments]) =>
        Object.entries(comments || {}).map(([commentId, comment]) => ({
          commentId,
          postSlug,
          ...(comment || {}),
        })),
      );

      items.sort((left, right) => {
        const reportDelta = Number(right.reportCount || 0) - Number(left.reportCount || 0);
        if (reportDelta !== 0) return reportDelta;
        return Number(right.createdAt || 0) - Number(left.createdAt || 0);
      });

      if (!commentsRoot) return;
      commentsRoot.dataset.comments = JSON.stringify(items);
      const visibleItems = activeFilter === 'reported'
        ? items.filter((item) => Number(item.reportCount || 0) > 0)
        : items;

      if (activeFilter === 'reported') {
        setSummary(`${visibleItems.length} reported comments loaded`);
      } else {
        setSummary(`${items.length} comments loaded`);
      }

      if (visibleItems.length === 0) {
        commentsRoot.innerHTML = '<p class="admin-empty">No comments found.</p>';
        return;
      }

      commentsRoot.innerHTML = visibleItems.map((item) => `
        <article class="admin-comment-card ${item.parentId ? 'is-reply' : ''}" data-comment-id="${escapeHtml(item.commentId)}" data-post-slug="${escapeHtml(item.postSlug)}">
          <div class="admin-comment-head">
            <div>
              <strong class="admin-comment-author">${escapeHtml(item.author || 'Unknown')}</strong>
              ${item.parentId ? `<p class="admin-comment-parent">Reply to ${escapeHtml(item.parentId)}</p>` : ''}
              <p class="admin-comment-meta">/${escapeHtml(item.postSlug)} · ${escapeHtml(formatDate(item.createdAt))}</p>
            </div>
            <div class="admin-comment-badges">
              <span class="admin-badge ${Number(item.reportCount || 0) > 0 ? 'is-hot' : ''}">Reports ${Number(item.reportCount || 0)}</span>
              <span class="admin-badge">ID ${escapeHtml(item.commentId)}</span>
            </div>
          </div>
          <p class="admin-comment-body">${escapeHtml(item.content || '')}</p>
          <div class="admin-comment-actions">
            <button type="button" class="admin-button admin-button-ghost" data-reset-report>Reset Reports</button>
            <button type="button" class="admin-button admin-button-danger" data-delete-comment>Delete</button>
          </div>
        </article>
      `).join('');
    } catch (error) {
      console.error('Failed to load admin comments.', error);
      if (commentsRoot) commentsRoot.innerHTML = '<p class="admin-empty">Failed to load comments.</p>';
      setSummary('Load failed');
    }
  }

  loginForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const formData = new FormData(loginForm);
    const email = String(formData.get('email') || '').trim();
    const password = String(formData.get('password') || '');

    if (!email || !password) {
      setAuthStatus('Email and password are required.', 'error');
      return;
    }

    setAuthStatus('Signing in...', 'neutral');

    try {
      await signInWithEmailAndPassword(auth, email, password);
      setAuthStatus('Signed in.', 'success');
    } catch (error) {
      console.error('Failed to sign in.', error);
      setAuthStatus('Failed to sign in. Check your credentials.', 'error');
    }
  });

  logoutButton?.addEventListener('click', async () => {
    await signOut(auth);
  });

  refreshButton?.addEventListener('click', async () => {
    await loadComments();
  });

  filterButtons.forEach((button) => {
    button.addEventListener('click', async () => {
      const nextFilter = button.dataset.adminFilter === 'reported' ? 'reported' : 'all';
      if (nextFilter === activeFilter) return;
      setActiveFilter(nextFilter);
      await loadComments();
    });
  });

  commentsRoot?.addEventListener('click', async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const card = target.closest('[data-comment-id]');
    if (!(card instanceof HTMLElement)) return;

    const commentId = card.dataset.commentId;
    const postSlug = card.dataset.postSlug;
    if (!commentId || !postSlug || !hasAdminAccess) return;

    if (target.matches('[data-delete-comment]')) {
      const confirmed = window.confirm('Delete this comment permanently?');
      if (!confirmed) return;

      try {
        const items = JSON.parse(commentsRoot?.dataset.comments || '[]');
        const descendantIds = collectDescendantIds(items, commentId);
        await Promise.all([
          remove(ref(database, `comments/${postSlug}/${commentId}`)),
          ...descendantIds.map((id) => remove(ref(database, `comments/${postSlug}/${id}`))),
        ]);
        await loadComments();
      } catch (error) {
        console.error('Failed to delete comment.', error);
        setAuthStatus('Failed to delete comment.', 'error');
      }
    }

    if (target.matches('[data-reset-report]')) {
      try {
        await update(ref(database, `comments/${postSlug}/${commentId}`), {
          reportCount: 0,
          lastReportedAt: 0,
        });
        await loadComments();
      } catch (error) {
        console.error('Failed to reset report count.', error);
        setAuthStatus('Failed to reset reports.', 'error');
      }
    }
  });

  onAuthStateChanged(auth, async (user) => {
    hasAdminAccess = false;

    if (!user) {
      if (userLabel) userLabel.textContent = 'Signed out';
      loginForm?.reset();
      setAuthStatus('', 'neutral');
      setScreenState(false);
      setAdminView(false);
      setAccess('Admin access required');
      setSummary('Not loaded');
      return;
    }

    if (userLabel) userLabel.textContent = user.email || user.uid;

    try {
      hasAdminAccess = await checkAdminAccess(user.uid);
      setAccess(hasAdminAccess ? 'Admin access granted' : 'Signed in, but not listed in admins/');

      if (hasAdminAccess) {
        setAuthStatus('', 'neutral');
        setScreenState(true);
        setAdminView(true);
        await loadComments();
      } else {
        setScreenState(false);
        setAdminView(false);
        setAuthStatus('관리자 권한이 없는 계정입니다.', 'error');
      }
    } catch (error) {
      console.error('Failed to check admin access.', error);
      setScreenState(false);
      setAdminView(false);
      setAccess('Failed to verify admin access');
      setAuthStatus('관리자 권한 확인에 실패했습니다.', 'error');
    }
  });
</script>

<style>
  .admin-auth-shell {
    min-height: calc(100vh - 140px);
    display: grid;
    place-items: center;
    padding: 96px 1.25rem 48px;
  }

  .admin-auth-card {
    width: min(100%, 440px);
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--bg-card);
    padding: 2rem;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.08);
  }

  .admin-shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 120px 1.25rem 80px;
  }

  .admin-auth-shell[hidden],
  .admin-shell[hidden],
  .admin-panel[hidden] {
    display: none !important;
  }

  .admin-header,
  .admin-card-head,
  .admin-toolbar,
  .admin-actions,
  .admin-status-row,
  .admin-comment-head,
  .admin-comment-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .admin-header {
    align-items: end;
    margin-bottom: 1.5rem;
  }

  .admin-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.45rem;
  }

  .admin-title {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 4vw, 3.8rem);
    line-height: 1.05;
    color: var(--ink);
  }

  .admin-subtitle {
    color: var(--ink-2);
    max-width: 56ch;
    margin-top: 0.85rem;
    line-height: 1.7;
  }

  .admin-user,
  .admin-status-row,
  .admin-comment-meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-3);
  }

  .admin-card {
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--bg-card);
    padding: 1.35rem;
  }

  .admin-card-wide {
    min-height: 520px;
  }

  .admin-card-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--ink);
  }

  .admin-card-copy {
    color: var(--ink-2);
    margin-top: 0.35rem;
  }

  .admin-toolbar,
  .admin-filters {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .admin-filter {
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: transparent;
    color: var(--ink-2);
    padding: 0.55rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .admin-filter.is-active {
    border-color: var(--ink);
    background: var(--ink);
    color: var(--bg);
  }

  .admin-form {
    margin-top: 1rem;
  }

  .admin-field {
    display: block;
    margin-bottom: 0.9rem;
  }

  .admin-field span {
    display: block;
    margin-bottom: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .admin-field input {
    width: 100%;
    border: 1px solid var(--border-strong);
    border-radius: 14px;
    background: var(--bg);
    color: var(--ink);
    padding: 0.85rem 0.95rem;
    font: inherit;
  }

  .admin-button {
    border: 1px solid var(--ink);
    border-radius: 999px;
    background: var(--ink);
    color: var(--bg);
    padding: 0.8rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .admin-button-ghost {
    border-color: var(--border-strong);
    background: transparent;
    color: var(--ink);
  }

  .admin-button-danger {
    border-color: #b42318;
    background: #b42318;
    color: #fff;
  }

  .admin-status {
    min-height: 1.4rem;
    margin-top: 0.8rem;
    font-size: 0.9rem;
  }

  .admin-status[data-tone="error"] {
    color: #b42318;
  }

  .admin-status[data-tone="success"] {
    color: #067647;
  }

  .admin-comments {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .admin-comment-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg);
    padding: 1.1rem 1.15rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.03);
  }

  .admin-comment-card.is-reply {
    margin-left: 2rem;
    border-left: 4px solid var(--accent);
  }

  .admin-comment-head {
    align-items: start;
  }

  .admin-comment-author {
    color: var(--ink);
  }

  .admin-comment-parent {
    margin-top: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
  }

  .admin-comment-body {
    margin: 0.9rem 0;
    line-height: 1.75;
    color: var(--ink-2);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .admin-comment-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .admin-badge {
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--ink-2);
    padding: 0.42rem 0.72rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    border: 1px solid transparent;
  }

  .admin-badge.is-hot {
    background: rgba(180, 35, 24, 0.1);
    color: #b42318;
    border-color: rgba(180, 35, 24, 0.16);
  }

  .admin-empty {
    color: var(--ink-3);
    padding: 2rem 0;
  }

  .admin-comment-actions {
    justify-content: flex-end;
    margin-top: 0.2rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--border);
  }

  .admin-comment-actions .admin-button {
    width: auto;
    min-width: 140px;
    padding: 0.78rem 1rem;
  }

  .admin-comment-actions .admin-button-ghost {
    background: var(--bg-card);
  }

  .admin-comment-actions .admin-button-danger {
    box-shadow: 0 10px 20px rgba(180, 35, 24, 0.16);
  }

  @media (max-width: 960px) {
    .admin-header,
    .admin-card-head,
    .admin-toolbar,
    .admin-actions,
    .admin-status-row,
    .admin-comment-head,
    .admin-comment-actions {
      align-items: start;
      flex-direction: column;
    }

    .admin-button {
      width: 100%;
    }

    .admin-comment-badges {
      justify-content: flex-start;
    }

    .admin-comment-actions .admin-button {
      width: 100%;
      min-width: 0;
    }

    .admin-comment-card.is-reply {
      margin-left: 0;
    }
  }

  @media (max-width: 640px) {
    .admin-auth-card {
      padding: 1.5rem;
    }

    .admin-shell {
      padding-top: 96px;
    }
  }
</style>
