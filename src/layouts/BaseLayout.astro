---
// src/layouts/BaseLayout.astro
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Evan Yoon | Pressing 'Restart' on Life", 
  description = "Former HR specialist (Josun Palace), Former GM (Blizzard) who decided to trade a stable career for code. Evan Yoon's journey." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,700;1,9..144,300&family=Geologica:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="fade-in">

<nav id="global-nav">
    <a href="/" class="nav-logo">Evan Yoon<span>.</span></a>
    <ul class="nav-links">
      <li><a href="/posts">All</a></li>
      <li><a href="/categories/tech">Tech & AI</a></li>
      <li><a href="/categories/study">Study</a></li>
      <li><a href="/categories/project">Projects</a></li>
      <li><a href="/categories/trouble">Trouble</a></li>
      <li><a href="/#about">About</a></li>
    </ul>
    <div class="nav-right">
      <button id="theme-toggle" aria-label="Toggle theme">☽</button>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <div class="footer-inner">
      <span class="footer-logo">Restart<span>.</span></span>
      <ul class="footer-links">
        <li><a href="https://github.com/winter31844" target="_blank">GitHub</a></li>
        <li><a href="https://medium.com/@winter31844" target="_blank">Medium</a></li>
        <li><a href="mailto:winter31844@gmail.com">Contact</a></li>
      </ul>
      <span class="footer-copy">© 2025 Evan Yoon · Built with ♥</span>
    </div>
  </footer>

  <!-- GoatCounter: 방문자 추적 -->
  <script data-goatcounter="https://evan-yoon.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

  <script is:inline>
    /* ── THEME TOGGLE (NO ANIMATION) ── */
    const toggle = document.getElementById('theme-toggle');
    const saved = localStorage.getItem('theme') || 'light';
    document.documentElement.dataset.theme = saved;
    toggle.textContent = saved === 'dark' ? '☀' : '☽';
    toggle.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
      toggle.textContent = next === 'dark' ? '☀' : '☽';
    });
  </script>

  <style is:global>
    /* ─── GLOBAL DESIGN TOKENS (NEW PALETTE) ─── */
    :root {
      --bg: #F9F9F7;        /* Off-White, easier on eyes */
      --bg-card: #FFFFFF;
      --bg-hover: #F2F2EF;
      --ink: #1A1A1A;       /* Near Black */
      --ink-2: #4D4D4D;     /* Gray */
      --ink-3: #808080;     /* Light Gray */
      --accent: #4A6785;    /* Deep Slate Blue (Rational, Professional) */
      --accent-soft: #EDF2F7;
      --accent-2: #C49B6A;  /* Muted Gold (Hint of Luxury/Premium past) */
      --accent-2-soft: #F9F5F0;
      --border: #EAEAE8;    /* Very Light Line */
      --border-strong: #DCDCDA;
      --font-serif: 'Fraunces', Georgia, serif;
      --font-sans: 'Geologica', system-ui, sans-serif; /* Highly readable */
      --font-mono: 'JetBrains Mono', monospace;
      --radius: 2px;       /* Minimalist */
      --max-w: 1100px;     /* Focused Reading Width */
      --col: 720px;        /* Single Column Reading Width */
      --transition: 0.15s ease-out; /* Fast, subtle */
    }

    [data-theme="dark"] {
      --bg: #121210;
      --bg-card: #191917;
      --bg-hover: #20201E;
      --ink: #EAEAE8;
      --ink-2: #B3B3B0;
      --ink-3: #7F7F7C;
      --accent: #8FAAC8;
      --accent-soft: #1D2631;
      --accent-2: #E0C7A8;
      --accent-2-soft: #2D261D;
      --border: #2A2A28;
      --border-strong: #3A3A38;
    }

    /* ─── RESET & BASE ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font-sans);
      font-weight: 300; /* Use light weight for Geologica as base */
      line-height: 1.6;
      transition: background var(--transition), color var(--transition);
      overflow-x: hidden;
    }
    body.fade-in { animation: bodyFadeIn 0.4s ease-out forwards; }
    @keyframes bodyFadeIn { from { opacity: 0; } to { opacity: 1; } }

    a { color: inherit; text-decoration: none; transition: color var(--transition); }
    img { display: block; max-width: 100%; }
    button { cursor: pointer; border: none; background: none; font: inherit; }

    /* ─── NAV CSS (STRUCTURAL & CLEAN) ─── */
    nav {
      position: sticky; top: 0; z-index: 100;
      padding: 0 2rem; height: 60px;
      display: flex; align-items: center; justify-content: space-between;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-family: var(--font-sans); font-size: 1rem; font-weight: 600; color: var(--ink); }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 2.5rem; align-items: center; list-style: none; }
    .nav-links a { font-size: 0.8rem; font-weight: 400; color: var(--ink-2); letter-spacing: 0.04em; text-transform: uppercase; }
    .nav-links a:hover { color: var(--ink); }
    .nav-right { display: flex; gap: 1rem; align-items: center; }
    #theme-toggle {
      width: 32px; height: 32px; border: 1px solid var(--border-strong);
      background: transparent; color: var(--ink-2); display: flex; align-items: center; justify-content: center;
      font-size: 0.85rem; transition: all var(--transition);
    }
    #theme-toggle:hover { background: var(--bg-hover); color: var(--ink); }

    /* ─── FOOTER CSS (SIMPLE) ─── */
    footer { border-top: 1px solid var(--border); padding: 4rem 2rem; }
    .footer-inner { max-width: var(--max-w); margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
    .footer-logo { font-family: var(--font-serif); font-size: 1.1rem; font-style: italic; color: var(--ink-2); }
    .footer-logo span { color: var(--accent); }
    .footer-links { display: flex; gap: 1.5rem; list-style: none; }
    .footer-links a { font-size: 0.75rem; color: var(--ink-3); letter-spacing: 0.06em; text-transform: uppercase; }
    .footer-links a:hover { color: var(--accent); }
    .footer-copy { font-size: 0.72rem; color: var(--ink-3); font-family: var(--font-mono); }

    /* ─── SCROLLBAR ─── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border-strong); }
    
    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 800px) {
      nav { padding: 0 1rem; }
      .nav-links { gap: 1.5rem; }
      .nav-links a { font-size: 0.75rem; }
    }
  </style>
</body>
</html>