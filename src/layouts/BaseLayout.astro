---
// src/layouts/BaseLayout.astro
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Evan Yoon | Pressing 'Restart' on Life",
  description = "Former HR specialist (Josun Palace), Former GM (Blizzard) who decided to trade a stable career for code. Evan Yoon's journey."
} = Astro.props;

const email = import.meta.env.EMAIL_ADDRESS ?? "winter31844@gmail.com";
const contactHref = email ? `mailto:${email}` : "/#about";
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,700;1,9..144,300&family=Geologica:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="fade-in">

<nav id="global-nav">
    <a href="/" class="nav-logo">Evan Yoon<span>.</span></a>
    <ul class="nav-links">
      <li><a href="/posts">All</a></li>
      <li><a href="/categories/explore">Explore</a></li>
      <li><a href="/categories/study">Study</a></li>
      <li><a href="/categories/project">Projects</a></li>
      <li><a href="/#about">About</a></li>
    </ul>
    <div class="nav-right">
      <button id="search-toggle" aria-label="Search" title="Search (Ctrl+Shift+P)">
      <button id="theme-toggle" aria-label="Toggle theme">☽</button>
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <button id="theme-toggle" aria-label="Toggle theme">??/button>
    </div>
  </nav>

  <!-- Search Modal -->
  <div id="search-overlay" aria-hidden="true">
    <div id="search-modal" role="dialog" aria-label="Search posts">
      <div id="search-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" id="search-icon-inline">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input id="search-input" type="text" placeholder="野꺜??깅선????낆젾??뤾쉭??.." autocomplete="off" spellcheck="false" />
        <kbd id="search-esc-hint">ESC</kbd>
      </div>
      <div id="search-results"></div>
      <div id="search-footer">
        <span><kbd>??/kbd><kbd>??/kbd> ??猷?/span>
        <span><kbd>??/kbd> ??용┛</span>
        <span><kbd>ESC</kbd> ??る┛</span>
      </div>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer>
    <div class="footer-inner">
      <span class="footer-logo">Restart<span>.</span></span>
      <ul class="footer-links">
        <li><a href="https://github.com/Evan-Yoon" target="_blank">GitHub</a></li>
        <li><a href={contactHref}>Contact</a></li>
      </ul>
      <span class="footer-copy">吏?2025 Evan Yoon</span>
    </div>
  </footer>

  <!-- GoatCounter: 獄쎻뫖揆???곕뗄??-->
  <script data-goatcounter="https://evan-yoon.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

  <script is:inline>
    /* ???? SEARCH ???? */
    (function () {
      let posts = null;
      let active = -1;

      const overlay = document.getElementById('search-overlay');
      const modal = document.getElementById('search-modal');
      const input = document.getElementById('search-input');
      const results = document.getElementById('search-results');
      const toggleBtn = document.getElementById('search-toggle');

      async function loadPosts() {
        if (posts) return;
        try {
          const res = await fetch('/search.json');
          posts = await res.json();
        } catch (e) {
          posts = [];
        }
      }

      function open() {
        overlay.classList.add('open');
        overlay.setAttribute('aria-hidden', 'false');
        input.value = '';
        results.innerHTML = '';
        active = -1;
        loadPosts().then(() => input.focus());
      }

      function close() {
        overlay.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
        input.blur();
      }

      function highlight(text, query) {
        if (!query) return text;
        const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark>$1</mark>');
      }

      function search(query) {
        if (!posts || !query.trim()) {
          results.innerHTML = '';
          active = -1;
          return;
        }
        const q = query.toLowerCase().trim();
        const matched = posts.filter(p => {
          const inTitle = p.title.toLowerCase().includes(q);
          const inDesc = (p.description || '').toLowerCase().includes(q);
          const inTags = (p.tags || []).some(t => t.toLowerCase().includes(q));
          const inCat = (p.category || '').toLowerCase().includes(q);
          return inTitle || inDesc || inTags || inCat;
        }).slice(0, 8);

        if (matched.length === 0) {
          results.innerHTML = '<div class="sr-empty">野껉퀗?드첎? ??곷뮸??덈뼄</div>';
          active = -1;
          return;
        }

        results.innerHTML = matched.map((p, i) => {
          const catClass = 'badge-' + (p.category || 'explore');
          const desc = p.description
            ? highlight(p.description.slice(0, 90) + (p.description.length > 90 ? '?? : ''), q)
            : '';
          return `<a class="sr-item" href="/posts/${p.slug}" data-index="${i}" tabindex="-1">
            <div class="sr-top">
              <span class="sr-title">${highlight(p.title, q)}</span>
              <span class="sr-meta">
                <span class="sr-cat ${catClass}">${p.category}</span>
                <span class="sr-date">${p.date}</span>
              </span>
            </div>
            ${desc ? `<p class="sr-desc">${desc}</p>` : ''}
          </a>`;
        }).join('');

        active = -1;
      }

      function setActive(idx) {
        const items = results.querySelectorAll('.sr-item');
        items.forEach(el => el.classList.remove('active'));
        if (idx >= 0 && idx < items.length) {
          items[idx].classList.add('active');
          items[idx].scrollIntoView({ block: 'nearest' });
          active = idx;
        } else {
          active = -1;
        }
      }

      toggleBtn.addEventListener('click', open);

      overlay.addEventListener('click', e => { if (e.target === overlay) close(); });

      input.addEventListener('input', () => search(input.value));

      input.addEventListener('keydown', e => {
        const items = results.querySelectorAll('.sr-item');
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          setActive(Math.min(active + 1, items.length - 1));
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          setActive(Math.max(active - 1, 0));
        } else if (e.key === 'Enter') {
          if (active >= 0 && items[active]) {
            close();
            window.location.href = items[active].href;
          }
        } else if (e.key === 'Escape') {
          close();
        }
      });

      results.addEventListener('click', e => {
        const item = e.target.closest('.sr-item');
        if (item) close();
      });

      results.addEventListener('mousemove', e => {
        const item = e.target.closest('.sr-item');
        if (item) setActive(parseInt(item.dataset.index, 10));
      });

      document.addEventListener('keydown', e => {
        if (e.ctrlKey && e.shiftKey && e.key === 'P') {
          e.preventDefault();
          overlay.classList.contains('open') ? close() : open();
        }
        if (e.key === 'Escape' && overlay.classList.contains('open')) close();
      });
    })();

    /* ???? THEME TOGGLE (NO ANIMATION) ???? */
    const toggle = document.getElementById('theme-toggle');
    const saved = localStorage.getItem('theme') || 'light';
    document.documentElement.dataset.theme = saved;
    toggle.textContent = saved === 'dark' ? '☀' : '☽';
    toggle.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
      toggle.textContent = next === 'dark' ? '☀' : '☽';
    });

    /* POST VIEW COUNTS */
    (function () {
      const site = 'https://evan-yoon.goatcounter.com';
      const selector = '[data-post-views][data-goatcounter-path]';
      const cache = new Map();

      function normalizePath(path) {
        if (!path) return '/';
        const trimmed = path.trim();
        if (!trimmed) return '/';
        return trimmed.endsWith('/') ? trimmed : `${trimmed}/`;
      }

      async function loadCount(path) {
        const normalized = normalizePath(path);
        if (cache.has(normalized)) return cache.get(normalized);

        const request = fetch(`${site}/counter/${encodeURIComponent(normalized)}.json`)
          .then((response) => {
            if (!response.ok) throw new Error(`Failed to load count for ${normalized}`);
            return response.json();
          })
          .then((data) => Number(data?.count ?? 0))
          .catch(() => 0);

        cache.set(normalized, request);
        return request;
      }

      async function renderCounts() {
        const nodes = Array.from(document.querySelectorAll(selector));
        if (nodes.length === 0) return;

        await Promise.all(
          [...new Set(nodes.map((node) => normalizePath(node.dataset.goatcounterPath || '')))].map((path) =>
            loadCount(path),
          ),
        );

        for (const node of nodes) {
          const count = await loadCount(node.dataset.goatcounterPath || '/');
          node.textContent = `views ${count.toLocaleString('ko-KR')}`;
        }
      }

      renderCounts();
    })();
  </script>

  <style is:global>
    /* ?????? GLOBAL DESIGN TOKENS (NEW PALETTE) ?????? */
    :root {
      --bg: #F9F9F7;        /* Off-White, easier on eyes */
      --bg-card: #FFFFFF;
      --bg-hover: #F2F2EF;
      --ink: #1A1A1A;       /* Near Black */
      --ink-2: #4D4D4D;     /* Gray */
      --ink-3: #808080;     /* Light Gray */
      --accent: #4A6785;    /* Deep Slate Blue (Rational, Professional) */
      --accent-soft: #EDF2F7;
      --accent-2: #C49B6A;  /* Muted Gold (Hint of Luxury/Premium past) */
      --accent-2-soft: #F9F5F0;
      --border: #EAEAE8;    /* Very Light Line */
      --border-strong: #DCDCDA;
      --font-serif: 'Fraunces', Georgia, serif;
      --font-sans: 'Geologica', system-ui, sans-serif; /* Highly readable */
      --font-mono: 'JetBrains Mono', monospace;
      --radius: 2px;       /* Minimalist */
      --max-w: 1100px;     /* Focused Reading Width */
      --col: 720px;        /* Single Column Reading Width */
      --transition: 0.15s ease-out; /* Fast, subtle */
    }

    [data-theme="dark"] {
      --bg: #121210;
      --bg-card: #191917;
      --bg-hover: #20201E;
      --ink: #EAEAE8;
      --ink-2: #B3B3B0;
      --ink-3: #7F7F7C;
      --accent: #8FAAC8;
      --accent-soft: #1D2631;
      --accent-2: #E0C7A8;
      --accent-2-soft: #2D261D;
      --border: #2A2A28;
      --border-strong: #3A3A38;
    }

    /* ?????? RESET & BASE ?????? */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font-sans);
      font-weight: 300; /* Use light weight for Geologica as base */
      line-height: 1.6;
      transition: background var(--transition), color var(--transition);
      overflow-x: clip;
    }
    body.fade-in { animation: bodyFadeIn 0.4s ease-out forwards; }
    @keyframes bodyFadeIn { from { opacity: 0; } to { opacity: 1; } }

    a { color: inherit; text-decoration: none; transition: color var(--transition); }
    img { display: block; max-width: 100%; }
    button { cursor: pointer; border: none; background: none; font: inherit; }

    /* ?????? NAV CSS (STRUCTURAL & CLEAN) ?????? */
    nav {
      position: sticky; top: 0; z-index: 100;
      padding: 0 2rem; height: 60px;
      display: flex; align-items: center; justify-content: space-between;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-family: var(--font-sans); font-size: 1rem; font-weight: 600; color: var(--ink); }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 2.5rem; align-items: center; list-style: none; }
    .nav-links a { font-size: 0.8rem; font-weight: 400; color: var(--ink-2); letter-spacing: 0.04em; text-transform: uppercase; }
    .nav-links a:hover { color: var(--ink); }
    .nav-right { display: flex; gap: 1rem; align-items: center; }
    #theme-toggle, #search-toggle {
      width: 32px; height: 32px; border: 1px solid var(--border-strong);
      background: transparent; color: var(--ink-2); display: flex; align-items: center; justify-content: center;
      font-size: 0.85rem; transition: all var(--transition);
    }
    #theme-toggle:hover, #search-toggle:hover { background: var(--bg-hover); color: var(--ink); }

    /* ?????? SEARCH MODAL ?????? */
    #search-overlay {
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(4px);
      display: flex; align-items: flex-start; justify-content: center;
      padding-top: 15vh;
      opacity: 0; pointer-events: none;
      transition: opacity 0.15s ease-out;
    }
    #search-overlay.open { opacity: 1; pointer-events: all; }

    #search-modal {
      width: 100%; max-width: 640px; margin: 0 1rem;
      background: var(--bg-card);
      border: 1px solid var(--border-strong);
      border-radius: 6px;
      box-shadow: 0 24px 64px rgba(0,0,0,0.25);
      overflow: hidden;
      transform: translateY(-8px);
      transition: transform 0.15s ease-out;
    }
    #search-overlay.open #search-modal { transform: translateY(0); }

    #search-header {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.85rem 1rem;
      border-bottom: 1px solid var(--border);
    }
    #search-icon-inline { color: var(--ink-3); flex-shrink: 0; }
    #search-input {
      flex: 1; background: none; border: none; outline: none;
      font-family: var(--font-sans); font-size: 0.95rem; color: var(--ink);
      caret-color: var(--accent);
    }
    #search-input::placeholder { color: var(--ink-3); }
    #search-esc-hint {
      font-family: var(--font-mono); font-size: 0.65rem; color: var(--ink-3);
      border: 1px solid var(--border-strong); border-radius: 3px;
      padding: 2px 6px; flex-shrink: 0;
    }

    #search-results { max-height: 420px; overflow-y: auto; }
    .sr-item {
      display: block; padding: 0.85rem 1rem;
      border-bottom: 1px solid var(--border);
      transition: background var(--transition);
      text-decoration: none; color: inherit;
    }
    .sr-item:last-child { border-bottom: none; }
    .sr-item:hover, .sr-item.active { background: var(--bg-hover); }
    .sr-top { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 0.25rem; }
    .sr-title { font-family: var(--font-serif); font-size: 1rem; font-weight: 400; color: var(--ink); flex: 1; min-width: 0; }
    .sr-title mark { background: var(--accent-soft); color: var(--accent); border-radius: 2px; padding: 0 2px; }
    .sr-meta { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
    .sr-cat { font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 2px 6px; border-radius: 2px; }
    .badge-study { background: var(--accent-2-soft); color: var(--accent-2); }
    .badge-project { background: #E6F0E6; color: #2E7D32; }
    .badge-explore { background: var(--accent-soft); color: var(--accent); }
    [data-theme="dark"] .badge-project { background: #1a2e1a; color: #66bb6a; }
    .sr-date { font-family: var(--font-mono); font-size: 0.7rem; color: var(--ink-3); white-space: nowrap; }
    .sr-desc { font-size: 0.8rem; color: var(--ink-2); line-height: 1.5; }
    .sr-desc mark { background: var(--accent-soft); color: var(--accent); border-radius: 2px; padding: 0 2px; }
    .sr-empty { padding: 2rem 1rem; text-align: center; color: var(--ink-3); font-size: 0.85rem; }

    #search-footer {
      display: flex; gap: 1.25rem; padding: 0.6rem 1rem;
      border-top: 1px solid var(--border);
      background: var(--bg);
    }
    #search-footer span { display: flex; align-items: center; gap: 0.3rem; font-size: 0.7rem; color: var(--ink-3); font-family: var(--font-mono); }
    #search-footer kbd {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 18px; height: 18px; padding: 0 4px;
      border: 1px solid var(--border-strong); border-radius: 3px;
      font-family: var(--font-mono); font-size: 0.65rem; color: var(--ink-2);
      background: var(--bg-card);
    }

    /* ?????? FOOTER CSS (SIMPLE) ?????? */
    footer { border-top: 1px solid var(--border); padding: 4rem 2rem; }
    .footer-inner { max-width: var(--max-w); margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
    .footer-logo { font-family: var(--font-serif); font-size: 1.1rem; font-style: italic; color: var(--ink-2); }
    .footer-logo span { color: var(--accent); }
    .footer-links { display: flex; gap: 1.5rem; list-style: none; }
    .footer-links a { font-size: 0.75rem; color: var(--ink-3); letter-spacing: 0.06em; text-transform: uppercase; }
    .footer-links a:hover { color: var(--accent); }
    .footer-copy { font-size: 0.72rem; color: var(--ink-3); font-family: var(--font-mono); }

    /* ?????? SCROLLBAR ?????? */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border-strong); }
    
    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 800px) {
      nav { padding: 0 1rem; }
      .nav-links { gap: 1.5rem; }
      .nav-links a { font-size: 0.75rem; }
    }
  </style>
</body>
</html>
