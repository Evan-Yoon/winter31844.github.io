---
import BaseLayout from './BaseLayout.astro';

const {
  frontmatter,
  postSlug,
  postPath,
  previousPost,
  nextPost,
  relatedPosts = [],
  headings = [],
} = Astro.props;

const categoryLabelMap: Record<string, string> = {
  study: 'Study',
  project: 'Project',
  explore: 'Explore',
};

const categoryLabel = categoryLabelMap[frontmatter.category as string] || frontmatter.category || 'Category';
const tocItems = (headings ?? []).filter((heading: { depth: number; slug: string; text: string }) => heading.depth === 2 || heading.depth === 3);
const showToc = frontmatter.toc !== false && tocItems.length > 0;
---

<BaseLayout title={`${frontmatter.title} | Evan Yoon`} description={frontmatter.description?.replace(/[\n\r]+/g, ' ').trim()}>
  <div class="progress-bar" id="progress"></div>

  <div class={`post-layout-outer ${showToc ? 'has-toc' : ''}`}>
  <div class="article-wrap fade-in-up">
    <header class="article-header">
      <div class="article-meta-row">
        <span class={`article-cat badge-${frontmatter.category || 'explore'}`}>{frontmatter.category || 'Explore'}</span>
        <span class="article-date">{new Date(frontmatter.date).toLocaleDateString('ko-KR')}</span>
        {frontmatter.readTime && <span class="article-read-time">/ {frontmatter.readTime}min read</span>}
        {postPath && <span class="article-view-count" data-post-views data-goatcounter-path={postPath}>/ views -</span>}
      </div>
      <h1 class="article-title">{frontmatter.title}</h1>
      {frontmatter.description && <p class="article-subtitle">{frontmatter.description}</p>}
    </header>

    <div class="article-structure-divider">
      <div class="struct-line"></div>
    </div>

    <div class="article-content-shell">
      <article class="article-body" id="article-body">
        <slot />

        {frontmatter.tags && (
          <div class="article-tags">
            {frontmatter.tags.map((tag: string) => (
              <span class="article-tag">#{tag}</span>
            ))}
          </div>
        )}

        {postSlug && (
          <section class="comments-section" data-comments-section data-post-slug={postSlug}>
            <div class="comments-header">
              <div>
                <p class="comments-kicker">Community</p>
                <h2 class="comments-title">Comments</h2>
              </div>
              <span class="comments-count" data-comments-count>0 comments</span>
            </div>

            <p class="comments-note">
              Comments appear immediately. Use report if something needs review.
            </p>

            <form class="comment-form" data-comment-form method="post" action="#" novalidate>
              <label class="comment-field">
                <span>Name</span>
                <input
                  type="text"
                  name="author"
                  maxlength="40"
                  placeholder="Your name"
                  required
                />
              </label>

              <label class="comment-field">
                <span>Comment</span>
                <textarea
                  name="content"
                  rows="5"
                  maxlength="500"
                  placeholder="Write something worth keeping."
                  required
                ></textarea>
              </label>

              <input
                class="comment-honeypot"
                type="text"
                name="website"
                tabindex="-1"
                autocomplete="off"
                aria-hidden="true"
              />

              <div class="comment-form-footer">
                <p class="comment-help">Max 40 chars for name, 500 chars for comment.</p>
                <button type="submit" class="comment-submit">Send Comment</button>
              </div>

              <p class="comment-status" data-comment-status aria-live="polite"></p>
            </form>

            <div class="comments-list" data-comments-list>
              <p class="comments-empty">No comments yet.</p>
            </div>
          </section>
        )}
      </article>
    </div>

    <section class="post-footer-nav" aria-label="Post navigation">
      <a
        class={`post-nav-card ${!previousPost ? 'is-disabled' : ''}`}
        href={previousPost ? `/posts/${previousPost.data.slug || previousPost.id}` : undefined}
        aria-disabled={!previousPost}
      >
        <span class="post-nav-label">이전 포스트</span>
        {previousPost ? (
          <>
            <strong class="post-nav-title">{previousPost.data.title}</strong>
            <span class="post-nav-meta">{new Date(previousPost.data.date).toLocaleDateString('ko-KR')}</span>
          </>
        ) : (
          <strong class="post-nav-title">첫 글입니다</strong>
        )}
      </a>

      <a
        class={`post-nav-card align-right ${!nextPost ? 'is-disabled' : ''}`}
        href={nextPost ? `/posts/${nextPost.data.slug || nextPost.id}` : undefined}
        aria-disabled={!nextPost}
      >
        <span class="post-nav-label">다음 포스트</span>
        {nextPost ? (
          <>
            <strong class="post-nav-title">{nextPost.data.title}</strong>
            <span class="post-nav-meta">{new Date(nextPost.data.date).toLocaleDateString('ko-KR')}</span>
          </>
        ) : (
          <strong class="post-nav-title">가장 최신 글입니다</strong>
        )}
      </a>
    </section>

    <section class="related-posts-section" aria-labelledby="related-posts-heading">
      <div class="related-posts-head">
        <div>
          <p class="related-kicker">{categoryLabel}</p>
          <h2 id="related-posts-heading" class="related-title">같은 카테고리의 다른 글</h2>
        </div>
        <a href={`/categories/${frontmatter.category}`} class="related-category-link">
          카테고리 전체 보기
        </a>
      </div>

      {relatedPosts.length > 0 ? (
        <>
          <div class="related-posts-grid" id="related-posts-grid">
            {relatedPosts.map((post: any, index: number) => (
              <article class={`related-post-card ${index >= 3 ? 'is-hidden' : ''}`}>
                <a href={`/posts/${post.data.slug || post.id}`} class="related-post-link">
                  <div class="related-post-meta">
                    <span class={`related-post-badge badge-${post.data.category || 'explore'}`}>
                      {post.data.category || 'explore'}
                    </span>
                    <span>{new Date(post.data.date).toLocaleDateString('ko-KR')}</span>
                  </div>
                  <h3 class="related-post-card-title">{post.data.title}</h3>
                  <p class="related-post-desc">
                    {post.data.description || '같은 카테고리에서 이어서 읽을 수 있는 글입니다.'}
                  </p>
                  <div class="related-post-footer">
                    <span>{post.data.readTime ? `${post.data.readTime} min read` : 'Read more'}</span>
                    <span class="post-view-count" data-post-views data-goatcounter-path={`/posts/${post.data.slug || post.id}/`}>views -</span>
                    <span class="related-post-arrow">→</span>
                  </div>
                </a>
              </article>
            ))}
          </div>

          {relatedPosts.length > 3 && (
            <div class="related-more-wrap">
              <button
                type="button"
                class="related-more-button"
                id="related-more-button"
                data-expanded="false"
              >
                더보기
              </button>
            </div>
          )}
        </>
      ) : (
        <div class="related-empty-state">
          같은 카테고리에 아직 다른 글이 없습니다.
        </div>
      )}
    </section>
  </div>

  {showToc && (
    <aside class="article-toc" aria-label="글 네비게이션" data-toc>
      <div class="article-toc-inner">
        <p class="article-toc-kicker">On This Page</p>
        <h2 class="article-toc-title">지금 읽는 위치</h2>
        <nav class="article-toc-nav">
          {tocItems.map((heading: { depth: number; slug: string; text: string }) => (
            <a
              class={`toc-link toc-depth-${heading.depth}`}
              href={`#${heading.slug}`}
              data-toc-link
              data-target={heading.slug}
            >
              <span class="toc-link-dot" aria-hidden="true"></span>
              <span class="toc-link-text">{heading.text}</span>
            </a>
          ))}
        </nav>
      </div>
    </aside>
  )}
  </div>
</BaseLayout>

<script>
  const bar = document.getElementById('progress');

  const updateReadingProgress = () => {
    if (!bar) return;
    const doc = document.documentElement;
    const scrollable = doc.scrollHeight - doc.clientHeight;
    const pct = scrollable > 0 ? (doc.scrollTop / scrollable) * 100 : 0;
    bar.style.width = `${Math.max(0, Math.min(100, pct))}%`;
  };

  updateReadingProgress();
  window.addEventListener('scroll', updateReadingProgress, { passive: true });

  const moreButton = document.getElementById('related-more-button');
  const relatedCards = Array.from(document.querySelectorAll('.related-post-card'));

  if (moreButton) {
    moreButton.addEventListener('click', () => {
      const expanded = moreButton.dataset.expanded === 'true';

      relatedCards.forEach((card, index) => {
        if (index >= 3) {
          card.classList.toggle('is-hidden', expanded);
        }
      });

      moreButton.dataset.expanded = expanded ? 'false' : 'true';
      moreButton.textContent = expanded ? '더보기' : '접기';
    });
  }

  const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
  const tocSections = tocLinks
    .map((link) => {
      const id = link.getAttribute('data-target');
      return id ? document.getElementById(id) : null;
    })
    .filter((el): el is HTMLElement => el !== null);

  if (tocLinks.length > 0 && tocSections.length > 0) {
    const visibleSections = new Map();

    const setActiveLink = (id: string) => {
      tocLinks.forEach((link) => {
        const isActive = link.getAttribute('data-target') === id;
        link.classList.toggle('is-active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    const getCurrentSectionId = () => {
      const sortedVisibleSections = Array.from(visibleSections.values()).sort(
        (left, right) => left.top - right.top,
      );

      if (sortedVisibleSections.length > 0) {
        return sortedVisibleSections[0].id;
      }

      const activationOffset = 140;
      let currentId = tocSections[0].id;

      tocSections.forEach((section) => {
        const { top } = section.getBoundingClientRect();
        if (top <= activationOffset) {
          currentId = section.id;
        }
      });

      return currentId;
    };

    setActiveLink(getCurrentSectionId());

    const syncActiveLink = () => {
      setActiveLink(getCurrentSectionId());
    };

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            visibleSections.set(entry.target.id, {
              id: entry.target.id,
              top: entry.boundingClientRect.top,
            });
          } else {
            visibleSections.delete(entry.target.id);
          }
        });

        syncActiveLink();
      },
      {
        rootMargin: '-96px 0px -55% 0px',
        threshold: [0, 0.1, 0.25, 0.5, 0.75, 1],
      },
    );

    tocSections.forEach((section) => sectionObserver.observe(section));
    window.addEventListener('scroll', syncActiveLink, { passive: true });

    tocLinks.forEach((link) => {
      link.addEventListener('click', (event) => {
        const id = link.getAttribute('data-target');
        const target = id ? document.getElementById(id) : null;
        if (!target) return;

        event.preventDefault();
        const top = target.getBoundingClientRect().top + window.scrollY - 92;
        window.history.replaceState({}, '', `#${id}`);
        window.scrollTo({ top, behavior: 'smooth' });
      });
    });
  }

</script>

<script>
  import { get, push, ref, runTransaction } from 'firebase/database';
  import { getFirebaseDatabase } from '../lib/firebase/client';

  const section = document.querySelector('[data-comments-section]');

  if (section) {
    const database = getFirebaseDatabase('comments');
    const postSlug = section.getAttribute('data-post-slug') || '';
    const form = section.querySelector('[data-comment-form]');
    const list = section.querySelector('[data-comments-list]');
    const count = section.querySelector('[data-comments-count]');
    const status = section.querySelector('[data-comment-status]');
    const commentsRef = ref(database, `comments/${postSlug}`);
    const submitCooldownKey = `comment_submit_${postSlug}`;
    const submitCooldownMs = 60_000;

    const formatDate = (value) => {
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '';
      return date.toLocaleDateString('ko-KR', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
      });
    };

    const setStatus = (message, tone = 'neutral') => {
      if (!status) return;
      status.textContent = message;
      status.dataset.tone = tone;
    };

    const setCount = (total) => {
      if (!count) return;
      count.textContent = `${total} comment${total === 1 ? '' : 's'}`;
    };

    const reportComment = async (commentId, reportButton) => {
      const storageKey = `comment_reported_${postSlug}_${commentId}`;
      if (localStorage.getItem(storageKey)) {
        setStatus('You already reported this comment from this browser.', 'error');
        return;
      }

      reportButton.disabled = true;

      try {
        const commentRef = ref(database, `comments/${postSlug}/${commentId}`);
        const result = await runTransaction(commentRef, (current) => {
          if (!current || typeof current !== 'object') return current;
          return {
            ...current,
            reportCount: Number(current.reportCount || 0) + 1,
            lastReportedAt: Date.now(),
          };
        });

        if (result.committed) {
          localStorage.setItem(storageKey, '1');
          setStatus('Comment reported.', 'success');
          await loadComments();
        } else {
          setStatus('Failed to report comment.', 'error');
        }
      } catch (error) {
        console.error('Failed to report comment.', error);
        setStatus('Failed to report comment. Please try again later.', 'error');
      } finally {
        reportButton.disabled = false;
      }
    };

    const renderComments = (items) => {
      if (!list) return;

      if (items.length === 0) {
        list.innerHTML = '<p class="comments-empty">No comments yet.</p>';
        setCount(0);
        return;
      }

      list.innerHTML = '';
      setCount(items.length);

      items.forEach((item) => {
        const article = document.createElement('article');
        article.className = 'comment-card';

        const header = document.createElement('div');
        header.className = 'comment-card-head';

        const author = document.createElement('strong');
        author.className = 'comment-author';
        author.textContent = item.author;

        const date = document.createElement('span');
        date.className = 'comment-date';
        date.textContent = formatDate(item.createdAt);

        const body = document.createElement('p');
        body.className = 'comment-body';
        body.textContent = item.content;

        const footer = document.createElement('div');
        footer.className = 'comment-card-footer';

        const reportMeta = document.createElement('span');
        reportMeta.className = 'comment-report-meta';
        reportMeta.textContent = `Reports ${Number(item.reportCount || 0)}`;

        const reportButton = document.createElement('button');
        reportButton.type = 'button';
        reportButton.className = 'comment-report-button';
        reportButton.textContent = 'Report';
        reportButton.addEventListener('click', () => reportComment(item.id, reportButton));

        footer.append(reportMeta, reportButton);
        header.append(author, date);
        article.append(header, body, footer);
        list.append(article);
      });
    };

    async function loadComments() {
      try {
        const snapshot = await get(commentsRef);
        const raw = snapshot.val() || {};
        const items = Object.entries(raw)
          .map(([id, item]) => ({ id, ...(item || {}) }))
          .filter((item) => item && typeof item === 'object')
          .sort((left, right) => Number(right.createdAt || 0) - Number(left.createdAt || 0));

        renderComments(items);
      } catch (error) {
        console.error('Failed to load comments.', error);
        if (list) {
          list.innerHTML = '<p class="comments-empty">Comments are temporarily unavailable.</p>';
        }
      }
    }

    loadComments();

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      event.stopPropagation();

      const now = Date.now();
      const lastSubmittedAt = Number(localStorage.getItem(submitCooldownKey) || 0);
      if (now - lastSubmittedAt < submitCooldownMs) {
        setStatus('Please wait a minute before sending another comment.', 'error');
        return;
      }

      const formData = new FormData(form);
      const author = String(formData.get('author') || '').trim();
      const content = String(formData.get('content') || '').trim();
      const website = String(formData.get('website') || '').trim();

      if (website) {
        setStatus('Comment rejected.', 'error');
        return;
      }

      if (author.length < 2 || author.length > 40) {
        setStatus('Name must be between 2 and 40 characters.', 'error');
        return;
      }

      if (content.length < 3 || content.length > 500) {
        setStatus('Comment must be between 3 and 500 characters.', 'error');
        return;
      }

      const submitButton = form.querySelector('button[type="submit"]');
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      setStatus('Saving comment...', 'neutral');

      try {
        await push(commentsRef, {
          author,
          content,
          createdAt: now,
          postSlug,
          reportCount: 0,
          lastReportedAt: 0,
        });

        localStorage.setItem(submitCooldownKey, String(now));
        form.reset();
        setStatus('Comment posted.', 'success');
        await loadComments();
      } catch (error) {
        console.error('Failed to save comment.', error);
        setStatus('Failed to save comment. Please try again later.', 'error');
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }
      }
    });
  }
</script>

<style is:global>
  .progress-bar {
    position: fixed;
    top: 60px;
    left: 0;
    height: 1.5px;
    background: var(--accent);
    width: 0%;
    z-index: 99;
  }

  .post-layout-outer {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .post-layout-outer.has-toc {
    max-width: calc(var(--max-w) + 300px + 3rem);
    display: flex;
    align-items: stretch;
    gap: 3rem;
  }

  .post-layout-outer.has-toc > .article-wrap {
    flex: 1;
    min-width: 0;
  }

  .article-wrap {
    padding-top: 60px;
    max-width: var(--max-w);
    margin: 0 auto;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
  }

  .fade-in-up {
    animation: fadeInUp 0.4s 0.1s ease-out forwards;
    opacity: 0;
    transform: translateY(10px);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .article-header {
    max-width: var(--col);
    margin: 0 auto;
    padding: 6rem 2rem 3rem;
    text-align: center;
  }

  .article-meta-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .article-cat {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    font-family: var(--font-mono);
  }

  .badge-study {
    background: var(--accent-2-soft);
    color: var(--accent-2);
  }

  .badge-project {
    background: #e6f0e6;
    color: #2e7d32;
  }

  .badge-explore {
    background: var(--accent-soft);
    color: var(--accent);
  }

  [data-theme="dark"] .badge-project {
    background: #1a2e1a;
    color: #66bb6a;
  }

  .article-date,
  .article-read-time,
  .article-view-count {
    font-size: 0.75rem;
    color: var(--ink-3);
    font-family: var(--font-mono);
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin-bottom: 1.5rem;
    white-space: pre-line;
  }

  .article-subtitle {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--ink-2);
    font-weight: 300;
    margin-bottom: 2rem;
    max-width: 35ch;
    white-space: pre-line;
    margin-left: auto;
    margin-right: auto;
  }

  .article-structure-divider {
    max-width: var(--max-w);
    margin: 0 auto 4rem;
    padding: 0 2rem;
    display: flex;
    align-items: center;
  }

  .struct-line {
    flex: 1;
    height: 1px;
    background: var(--border);
    position: relative;
  }

  .struct-line::before,
  .struct-line::after {
    content: '';
    position: absolute;
    top: -3px;
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
  }

  .struct-line::before {
    left: 0;
  }

  .struct-line::after {
    right: 0;
  }

  .article-content-shell {
    max-width: calc(var(--col) + 4rem);
    margin: 0 auto;
    padding: 0 2rem 8rem;
  }


  .article-body {
    min-width: 0;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  .article-body h1,
  .article-body h2,
  .article-body h3 {
    scroll-margin-top: 92px;
  }

  .article-body h1 {
    font-family: var(--font-serif);
    font-size: 2.1rem;
    font-weight: 400;
    color: var(--ink);
    margin: 4rem 0 1.5rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .article-body h2 {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--ink);
    margin: 3.5rem 0 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .article-body h3 {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--ink);
    margin: 2.5rem 0 1rem;
  }

  .article-body p {
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--ink-2);
    font-weight: 400;
    margin-bottom: 1.6rem;
    letter-spacing: -0.005em;
    word-break: keep-all;
  }

  .article-body strong {
    color: var(--ink);
    font-weight: 600;
  }

  .article-body em {
    font-style: italic;
  }

  .article-body a {
    color: var(--accent);
    border-bottom: 1px solid var(--accent-soft);
    transition: border-color var(--transition);
  }

  .article-body a:hover {
    border-color: var(--accent);
  }

  .article-body ul,
  .article-body ol {
    padding-left: 1.5rem;
    margin-bottom: 1.6rem;
  }

  .article-body li {
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--ink-2);
    font-weight: 400;
    margin-bottom: 0.5rem;
    word-break: keep-all;
  }

  .article-body blockquote {
    margin: 3rem 0;
    padding: 1.5rem 2.5rem;
    border-left: 1px solid var(--accent-2);
    background: var(--bg-card);
    position: relative;
    border-radius: var(--radius);
  }

  .article-body blockquote p {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-style: italic;
    font-weight: 300;
    color: var(--ink);
    margin: 0;
    line-height: 1.7;
