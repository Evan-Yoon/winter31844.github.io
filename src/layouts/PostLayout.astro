---
// src/layouts/PostLayout.astro
import BaseLayout from './BaseLayout.astro';

const {
  frontmatter,
  previousPost,
  nextPost,
  relatedPosts = [],
} = Astro.props;

const categoryLabelMap = {
  study: 'Study',
  project: 'Project',
  explore: 'Explore',
};

const categoryLabel = categoryLabelMap[frontmatter.category] || frontmatter.category || 'Category';
---

<BaseLayout title={`${frontmatter.title} | Evan Yoon`} description={frontmatter.description}>
  <div class="progress-bar" id="progress"></div>

  <div class="article-wrap fade-in-up">
    <header class="article-header">
      <div class="article-meta-row">
        <span class={`article-cat badge-${frontmatter.category || 'explore'}`}>{frontmatter.category || 'Explore'}</span>
        <span class="article-date">{new Date(frontmatter.date).toLocaleDateString('ko-KR')}</span>
        {frontmatter.readTime && <span class="article-read-time">/ {frontmatter.readTime}min read</span>}
      </div>
      <h1 class="article-title">{frontmatter.title}</h1>
      {frontmatter.description && <p class="article-subtitle">{frontmatter.description}</p>}
    </header>

    <div class="article-structure-divider">
      <div class="struct-line"></div>
    </div>

    <article class="article-body">
      <slot />
      
      {frontmatter.tags && (
        <div class="article-tags">
          {frontmatter.tags.map((tag: string) => (
            <span class="article-tag">#{tag}</span>
          ))}
        </div>
      )}
    </article>

    <section class="post-footer-nav" aria-label="Post navigation">
      <a
        class={`post-nav-card ${!previousPost ? 'is-disabled' : ''}`}
        href={previousPost ? `/posts/${previousPost.data.slug || previousPost.id}` : undefined}
        aria-disabled={!previousPost}
      >
        <span class="post-nav-label">이전 포스트</span>
        {previousPost ? (
          <>
            <strong class="post-nav-title">{previousPost.data.title}</strong>
            <span class="post-nav-meta">{new Date(previousPost.data.date).toLocaleDateString('ko-KR')}</span>
          </>
        ) : (
          <strong class="post-nav-title">첫 글에 도달했습니다</strong>
        )}
      </a>

      <a
        class={`post-nav-card align-right ${!nextPost ? 'is-disabled' : ''}`}
        href={nextPost ? `/posts/${nextPost.data.slug || nextPost.id}` : undefined}
        aria-disabled={!nextPost}
      >
        <span class="post-nav-label">다음 포스트</span>
        {nextPost ? (
          <>
            <strong class="post-nav-title">{nextPost.data.title}</strong>
            <span class="post-nav-meta">{new Date(nextPost.data.date).toLocaleDateString('ko-KR')}</span>
          </>
        ) : (
          <strong class="post-nav-title">가장 최신 글입니다</strong>
        )}
      </a>
    </section>

    <section class="related-posts-section" aria-labelledby="related-posts-heading">
      <div class="related-posts-head">
        <div>
          <p class="related-kicker">{categoryLabel}</p>
          <h2 id="related-posts-heading" class="related-title">카테고리의 다른 글</h2>
        </div>
        <a href={`/categories/${frontmatter.category}`} class="related-category-link">
          카테고리 전체 보기
        </a>
      </div>

      {relatedPosts.length > 0 ? (
        <>
          <div class="related-posts-grid" id="related-posts-grid">
            {relatedPosts.map((post, index) => (
              <article class={`related-post-card ${index >= 3 ? 'is-hidden' : ''}`}>
                <a href={`/posts/${post.data.slug || post.id}`} class="related-post-link">
                  <div class="related-post-meta">
                    <span class={`related-post-badge badge-${post.data.category || 'explore'}`}>
                      {post.data.category || 'explore'}
                    </span>
                    <span>{new Date(post.data.date).toLocaleDateString('ko-KR')}</span>
                  </div>
                  <h3 class="related-post-card-title">{post.data.title}</h3>
                  <p class="related-post-desc">
                    {post.data.description || '같은 카테고리에서 이어서 읽을 수 있는 글입니다.'}
                  </p>
                  <div class="related-post-footer">
                    <span>{post.data.readTime ? `${post.data.readTime} min read` : 'Read more'}</span>
                    <span class="related-post-arrow">→</span>
                  </div>
                </a>
              </article>
            ))}
          </div>

          {relatedPosts.length > 3 && (
            <div class="related-more-wrap">
              <button
                type="button"
                class="related-more-button"
                id="related-more-button"
                data-expanded="false"
              >
                더보기
              </button>
            </div>
          )}
        </>
      ) : (
        <div class="related-empty-state">
          같은 카테고리에 아직 다른 글이 없습니다.
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<script>
  /* READING PROGRESS (NO ANIMATION ON JS) */
  const bar = document.getElementById('progress');
  window.addEventListener('scroll', () => {
    if(bar) {
      const doc = document.documentElement;
      const pct = (doc.scrollTop / (doc.scrollHeight - doc.clientHeight)) * 100;
      bar.style.width = pct + '%';
    }
  });

  const moreButton = document.getElementById('related-more-button');
  const relatedCards = Array.from(document.querySelectorAll('.related-post-card'));

  if (moreButton) {
    moreButton.addEventListener('click', () => {
      const expanded = moreButton.dataset.expanded === 'true';

      relatedCards.forEach((card, index) => {
        if (index >= 3) {
          card.classList.toggle('is-hidden', expanded);
        }
      });

      moreButton.dataset.expanded = expanded ? 'false' : 'true';
      moreButton.textContent = expanded ? '더보기' : '접기';
    });
  }
</script>

<style is:global>
  /* ─── POST LAYOUT & TYPOGRAPHY STYLES (Focused on Reading) ─── */
  .progress-bar { position: fixed; top: 60px; left: 0; height: 1.5px; background: var(--accent); width: 0%; z-index: 99; }
  
  .article-wrap { padding-top: 60px; max-width: var(--max-w); margin: 0 auto; border-left: 1px solid var(--border); border-right: 1px solid var(--border); }
  /* Simple load animation for the article only */
  .fade-in-up { animation: fadeInUp 0.4s 0.1s ease-out forwards; opacity: 0; transform: translateY(10px); }
  @keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }

  .article-header { max-width: var(--col); margin: 0 auto; padding: 6rem 2rem 3rem; text-align: center; }
  .article-meta-row { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 2rem; }
  .article-cat { font-size: 0.65rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 10px; border-radius: 2px; font-family: var(--font-mono); }
  
  /* Category Badge Colors updated to Slate palette */
  .badge-study { background: var(--accent-2-soft); color: var(--accent-2); }
  .badge-project { background: #E6F0E6; color: #2E7D32; }
  .badge-explore { background: var(--accent-soft); color: var(--accent); }
  [data-theme="dark"] .badge-project { background: #1A2E1A; color: #66BB6A; }

  .article-date, .article-read-time { font-size: 0.75rem; color: var(--ink-3); font-family: var(--font-mono); }
  .article-title { font-family: var(--font-serif); font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 300; line-height: 1.08; letter-spacing: -0.04em; color: var(--ink); margin-bottom: 1.5rem; }
  .article-subtitle { font-size: 1.1rem; line-height: 1.7; color: var(--ink-2); font-weight: 300; margin-bottom: 2rem; max-width: 35ch; margin-left: auto; margin-right: auto; }
  
  .article-structure-divider { max-width: var(--max-w); margin: 0 auto 4rem; padding: 0 2rem; display: flex; align-items: center; }
  .struct-line { flex: 1; height: 1px; background: var(--border); position: relative; }
  .struct-line::before { content: ''; position: absolute; left: 0; top: -3px; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }
  .struct-line::after { content: ''; position: absolute; right: 0; top: -3px; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }
  
  .article-body { max-width: var(--col); margin: 0 auto; padding: 0 2rem 8rem; }
  
  /* Content Typography: Use Geologica with slightly heavier base weight for reading */
  .article-body h2 { font-family: var(--font-serif); font-size: 1.8rem; font-weight: 400; color: var(--ink); margin: 3.5rem 0 1.25rem; line-height: 1.2; letter-spacing: -0.01em; }
  .article-body h3 { font-family: var(--font-sans); font-size: 1.15rem; font-weight: 600; color: var(--ink); margin: 2.5rem 0 1rem; }
  
  .article-body p { font-size: 1.05rem; line-height: 1.9; color: var(--ink-2); font-weight: 400; /* Medium weight for readable Geologica */ margin-bottom: 1.6rem; letter-spacing: -0.005em; }
  .article-body strong { color: var(--ink); font-weight: 600; }
  .article-body em { font-style: italic; }
  .article-body a { color: var(--accent); border-bottom: 1px solid var(--accent-soft); transition: border-color var(--transition); }
  .article-body a:hover { border-color: var(--accent); }
  
  .article-body ul, .article-body ol { padding-left: 1.5rem; margin-bottom: 1.6rem; }
  .article-body li { font-size: 1.05rem; line-height: 1.9; color: var(--ink-2); font-weight: 400; margin-bottom: 0.5rem; }
  
  .article-body blockquote { margin: 3rem 0; padding: 1.5rem 2.5rem; border-left: 1px solid var(--accent-2); background: var(--bg-card); position: relative; border-radius: var(--radius); }
  .article-body blockquote p { font-family: var(--font-serif); font-size: 1.2rem; font-style: italic; font-weight: 300; color: var(--ink); margin: 0; line-height: 1.7; }
  
  .article-body code { font-family: var(--font-mono); font-size: 0.85em; background: var(--accent-soft); color: var(--accent); padding: 3px 6px; border-radius: 2px; }
  .article-body pre { margin: 2.5rem 0; border-radius: var(--radius); background: #1A1917; padding: 1.5rem; overflow-x: auto; border: 1px solid var(--border-strong); }
  [data-theme="dark"] .article-body pre { background: #0D0B08; }
  .article-body pre code { color: #E8E4DC; background: none; border: none; padding: 0; font-size: 0.875rem; }
  
  /* ─── 이미지 ─── */
  .article-body img {
    width: 100%;
    max-width: min(100%, 680px);
    display: block;
    border-radius: 12px;
    border: 1px solid var(--border);
    margin: 2.25rem auto;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
  }
  /* 수동 삽입: ![alt](url "caption") → title이 있으면 figcaption처럼 표시 */
  .article-body p:has(img) {
    margin: 0 auto; /* img 자체에 margin 있으므로 p margin 제거 */
    max-width: 760px;
  }
  /* 자동 삽입 이미지 래퍼 */
  .auto-image-wrap {
    margin: 0;
  }
  /* alt 텍스트를 캡션으로 표시 (이미지 바로 다음 em 태그 없이, CSS content 활용 불가 → JS 없이 처리 한계) */

  .article-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 4rem 0 0; padding-top: 2rem; border-top: 1px solid var(--border); }
  .article-tag { font-size: 0.7rem; padding: 4px 12px; border-radius: 100px; border: 1px solid var(--border-strong); color: var(--ink-3); font-family: var(--font-mono); font-weight: 400; }
  .article-tag:hover { border-color: var(--accent-2); color: var(--accent-2); }

  .post-footer-nav {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem 2rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  .post-nav-card {
    min-height: 164px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.85rem;
    padding: 1.5rem;
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    background:
      linear-gradient(135deg, var(--bg-card) 0%, var(--bg-hover) 100%);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }
  .post-nav-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.06);
  }
  .post-nav-card.align-right { text-align: right; }
  .post-nav-card.is-disabled {
    opacity: 0.55;
    pointer-events: none;
  }
  .post-nav-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .post-nav-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    line-height: 1.35;
    color: var(--ink);
  }
  .post-nav-meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-3);
  }

  .related-posts-section {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1rem 2rem 6rem;
  }
  .related-posts-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .related-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.6rem;
  }
  .related-title {
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 3vw, 2.2rem);
    font-weight: 400;
    color: var(--ink);
  }
  .related-category-link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-3);
    padding-bottom: 0.2rem;
    border-bottom: 1px solid transparent;
  }
  .related-category-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .related-posts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  .related-post-card.is-hidden {
    display: none;
  }
  .related-post-link {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.35rem;
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    background: var(--bg-card);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }
  .related-post-link:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.05);
  }
  .related-post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink-3);
  }
  .related-post-badge {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 999px;
  }
  .related-post-card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    line-height: 1.35;
    color: var(--ink);
  }
  .related-post-desc {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--ink-2);
    flex: 1;
  }
  .related-post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--ink-3);
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .related-post-arrow {
    font-size: 1rem;
    color: var(--accent);
  }
  .related-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }
  .related-more-button {
    padding: 0.9rem 1.5rem;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: var(--bg-card);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: border-color var(--transition), background var(--transition), color var(--transition);
  }
  .related-more-button:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent);
  }
  .related-empty-state {
    padding: 1.5rem;
    border: 1px dashed var(--border-strong);
    border-radius: 16px;
    color: var(--ink-3);
    background: var(--bg-hover);
  }

  @media (max-width: 768px) {
    .article-wrap { border: none; padding-top: 20px; }
    .article-title { font-size: 2rem; }
    .article-header { padding: 4rem 1rem 2rem; }
    .article-body { padding: 0 1rem 5rem; }
    .article-meta-row { flex-wrap: wrap; gap: 0.5rem 1rem; }
    .post-footer-nav { grid-template-columns: 1fr; padding: 0 1rem 1.5rem; }
    .post-nav-card, .post-nav-card.align-right { text-align: left; min-height: auto; }
    .related-posts-section { padding: 1rem 1rem 4rem; }
    .related-posts-head { align-items: start; flex-direction: column; }
    .related-posts-grid { grid-template-columns: 1fr; }
  }
</style>
