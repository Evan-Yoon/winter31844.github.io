<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:controller="study02.rootController"
      alignment="CENTER"
      prefHeight="500.0" prefWidth="1200.0"
      spacing="20.0"
      styleClass="main-background"
      stylesheets="@application.css"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

   <children>
      <VBox alignment="CENTER" spacing="5">
          <Label text="DATA LABELING" styleClass="title-label" />
          <Label fx:id="lblPg" text="1 / 100" styleClass="status-label" />
      </VBox>

      <StackPane styleClass="card-pane" prefHeight="200" maxWidth="1100">
         <children>
            <Label fx:id="lblData"
                   text="데이터 로딩 중..."
                   wrapText="true"
                   textAlignment="CENTER"
                   styleClass="data-label" />
         </children>
         <padding>
             <Insets top="30" right="30" bottom="30" left="30"/>
         </padding>
      </StackPane>

      <HBox alignment="CENTER" spacing="30.0" prefHeight="100.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onActionLikeBtn"
                    text="긍정 (Positive)" styleClass="btn, btn-positive" />

            <Button mnemonicParsing="false" onAction="#onActionNeutralBtn"
                    text="중립 (Neutral)" styleClass="btn, btn-neutral" />

            <Button mnemonicParsing="false" onAction="#onActionDislikeBtn"
                    text="부정 (Negative)" styleClass="btn, btn-negative" />
         </children>
      </HBox>
   </children>

   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>