<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="study03.rootController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label styleClass="label-title" text="AI 감정 분석기" />

    <Label styleClass="label-instruction" text="아래에 문장을 입력하고 분석 버튼을 눌러주세요." />

    <HBox alignment="CENTER" spacing="10.0">
        <TextField fx:id="tfSentence" prefWidth="350.0" promptText="여기에 문장을 입력하세요..." />

        <Button fx:id="btnAnalyze" onAction="#onActionAnalyzeBtn" styleClass="button-analyze" text="분석하기" />
    </HBox>

    <VBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
        <padding>
            <Insets bottom="20.0" top="20.0" />
        </padding>
        <Label styleClass="label-result-title" text="분석 결과" />
        <Label fx:id="lblResult" styleClass="label-result-value" text="대기 중..." />
    </VBox>
</VBox>