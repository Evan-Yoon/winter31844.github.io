    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Load the datasets\n",
    "store_df = pd.read_csv('store.csv')\n",
    "train_df = pd.read_csv('train.csv', parse_dates=['Date'], low_memory=False)\n",
    "\n",
    "# Merge the datasets on 'Store'\n",
    "merged_df = pd.merge(train_df, store_df, on='Store', how='left')\n",
    "\n",
    "# Extract date features\n",
    "merged_df['Year'] = merged_df['Date'].dt.year\n",
    "merged_df['Month'] = merged_df['Date'].dt.month\n",
    "merged_df['DayOfWeek'] = merged_df['Date'].dt.dayofweek # 0: Mon, 6: Sun\n",
    "\n",
    "# Filter out closed stores for sales analysis (Sales > 0 and Open == 1)\n",
    "# Although Sales can be 0 when Open=1 (rarely), usually we analyze open days.\n",
    "sales_df = merged_df[(merged_df['Open'] == 1) & (merged_df['Sales'] > 0)]\n",
    "\n",
    "# Display info to check merge and data\n",
    "print(sales_df.info())\n",
    "print(sales_df.head())\n",
    "\n",
    "# --- Analysis for Strategy ---\n",
    "\n",
    "# 1. Sales by StoreType and Assortment\n",
    "plt.figure(figsize=(12, 5))\n",
    "plt.subplot(1, 2, 1)\n",
    "sns.barplot(x='StoreType', y='Sales', data=sales_df, order=['a', 'b', 'c', 'd'])\n",
    "plt.title('Average Sales by Store Type')\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "sns.barplot(x='Assortment', y='Sales', data=sales_df, order=['a', 'b', 'c'])\n",
    "plt.title('Average Sales by Assortment')\n",
    "plt.tight_layout()\n",
    "plt.savefig('sales_by_type_assortment.png')\n",
    "\n",
    "# 2. Impact of Promo\n",
    "plt.figure(figsize=(6, 5))\n",
    "sns.barplot(x='Promo', y='Sales', data=sales_df)\n",
    "plt.title('Average Sales: Promo vs No Promo')\n",
    "plt.savefig('sales_by_promo.png')\n",
    "\n",
    "# 3. Competition Distance vs Sales\n",
    "# Since there are many data points, we'll use a hexbin plot or sample,\n",
    "# but for simplicity and clarity in trend, let's aggregate by Store first.\n",
    "avg_sales_per_store = sales_df.groupby('Store')[['Sales', 'CompetitionDistance', 'StoreType']].mean().reset_index()\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "sns.scatterplot(x='CompetitionDistance', y='Sales', hue='StoreType', data=avg_sales_per_store, alpha=0.6)\n",
    "plt.title('Average Sales vs Competition Distance (per Store)')\n",
    "plt.savefig('sales_vs_distance.png')\n",
    "\n",
    "# 4. Seasonality (Month)\n",
    "plt.figure(figsize=(10, 5))\n",
    "sns.lineplot(x='Month', y='Sales', hue='StoreType', data=sales_df)\n",
    "plt.title('Monthly Sales Trend by Store Type')\n",
    "plt.savefig('sales_seasonality.png')\n",
