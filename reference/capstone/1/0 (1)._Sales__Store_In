    "plt.tight_layout()\n",
    "plt.savefig('sales_by_type_assortment.png')\n",
    "\n",
    "# 2. Impact of Promo\n",
    "plt.figure(figsize=(6, 5))\n",
    "sns.barplot(x='Promo', y='Sales', data=sales_df)\n",
    "plt.title('Average Sales: Promo vs No Promo')\n",
    "plt.savefig('sales_by_promo.png')\n",
    "\n",
