    "# Correcting the groupby issue: group by both Store and StoreType\n",
    "avg_sales_per_store = sales_df.groupby(['Store', 'StoreType'])[['Sales', 'CompetitionDistance']].mean().reset_index()\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "sns.scatterplot(x='CompetitionDistance', y='Sales', hue='StoreType', data=avg_sales_per_store, alpha=0.6)\n",
